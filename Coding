{tier:4,icon:"⏱️",name:"Coroutines & Timers",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(244,114,182,0.1);color:#f472b6">Tier 5 — Unity Gameplay</div>
  <h1>⏱️ Coroutines &amp; Timers</h1>
  <p>Run code over time — spawn enemies on a delay, create countdown timers, fade things in and out.</p>
  <div class="badges"><span class="badge unity">★ IEnumerator</span><span class="badge unity">★ yield return</span><span class="badge unity">★ WaitForSeconds</span><span class="badge unity">★ StartCoroutine</span><span class="badge unity">★ Invoke</span></div>
</div>

<div class="section">
  <h2>💻 Coroutine Basics</h2>
  <pre><span class="kw">using</span> System.Collections;  <span class="cm">// required for IEnumerator</span>

<span class="cm">// ── Define a coroutine ──</span>
<span class="ty">IEnumerator</span> <span class="fn">SpawnAfterDelay</span>(<span class="ty">float</span> delay)
{
    <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Waiting..."</span>);
    <span class="kw">yield return new</span> <span class="ty">WaitForSeconds</span>(delay);  <span class="cm">// PAUSES here, then resumes</span>
    <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Spawning enemy!"</span>);
    <span class="uk">Instantiate</span>(enemyPrefab, spawnPoint.position, <span class="ty">Quaternion</span>.identity);
}

<span class="cm">// ── Start a coroutine ──</span>
<span class="kw">void</span> <span class="fn">Start</span>()
{
    <span class="fn">StartCoroutine</span>(<span class="fn">SpawnAfterDelay</span>(<span class="num">2f</span>));
}

<span class="cm">// ── Countdown timer coroutine ──</span>
<span class="ty">IEnumerator</span> <span class="fn">Countdown</span>(<span class="ty">int</span> seconds)
{
    <span class="kw">for</span> (<span class="ty">int</span> i = seconds; i &gt; <span class="num">0</span>; i--)
    {
        timerText.text = i.ToString();
        <span class="kw">yield return new</span> <span class="ty">WaitForSeconds</span>(<span class="num">1f</span>);
    }
    timerText.text = <span class="str">"GO!"</span>;
    <span class="fn">StartGame</span>();
}

<span class="cm">// ── Repeating spawn coroutine ──</span>
<span class="ty">IEnumerator</span> <span class="fn">SpawnWaves</span>()
{
    <span class="kw">while</span> (<span class="kw">true</span>)   <span class="cm">// runs forever until StopCoroutine</span>
    {
        <span class="fn">SpawnEnemy</span>();
        <span class="kw">yield return new</span> <span class="ty">WaitForSeconds</span>(spawnInterval);
    }
}</pre>
</div>

<div class="section">
  <h2>💻 Invoke — Simpler Delays</h2>
  <pre><span class="cm">// Invoke — calls a method after a delay (no IEnumerator needed)</span>
<span class="fn">Invoke</span>(<span class="str">"Die"</span>, <span class="num">3f</span>);               <span class="cm">// calls Die() after 3 seconds</span>
<span class="fn">InvokeRepeating</span>(<span class="str">"SpawnCoin"</span>, <span class="num">1f</span>, <span class="num">2f</span>); <span class="cm">// start 1s, repeat every 2s</span>
<span class="fn">CancelInvoke</span>(<span class="str">"SpawnCoin"</span>);       <span class="cm">// stop repeating</span>

<span class="cm">// Manual timer in Update() — simple but effective</span>
<span class="ty">float</span> timer = <span class="num">0f</span>;
<span class="ty">float</span> interval = <span class="num">5f</span>;

<span class="kw">void</span> <span class="fn">Update</span>()
{
    timer += <span class="uk">Time</span>.deltaTime;
    <span class="kw">if</span> (timer &gt;= interval)
    {
        timer = <span class="num">0f</span>;
        <span class="fn">DoSomethingEvery5Seconds</span>();
    }
}</pre>

  <table class="ctable" style="margin-top:10px">
    <tr><th>Method</th><th>When to use</th><th>Can pass parameters?</th></tr>
    <tr><td><code>Invoke()</code></td><td>Simple one-off delay</td><td>No</td></tr>
    <tr><td><code>InvokeRepeating()</code></td><td>Repeat on fixed interval</td><td>No</td></tr>
    <tr><td><code>StartCoroutine()</code></td><td>Complex sequences, parameters, loops</td><td>Yes</td></tr>
    <tr><td><code>Update() timer</code></td><td>Simple frame-based checks</td><td>Yes (variables)</td></tr>
  </table>
</div>

${Q([
  {q:"What return type must a coroutine method have?",opts:["void","bool","IEnumerator","Coroutine"],ans:2,explain:"All coroutine methods must return IEnumerator. This is what allows Unity to pause and resume execution at yield points."},
  {q:"What does <code>yield return new WaitForSeconds(2f)</code> do?",opts:["Ends the coroutine","Pauses execution for 2 seconds, then continues from the next line","Loops for 2 seconds","Waits until the next frame"],ans:1,explain:"yield return pauses the coroutine at that point. After 2 seconds have passed, Unity resumes execution from the line after the yield statement."},
  {q:"How do you START a coroutine?",opts:["Call it directly: SpawnEnemy()","Coroutine.Run(SpawnEnemy())","StartCoroutine(SpawnEnemy())","Start(SpawnEnemy)"],ans:2,explain:"You must use StartCoroutine() to begin a coroutine. Calling the method directly just returns an IEnumerator object — nothing actually runs."},
  {q:"When would you use <code>Invoke()</code> instead of a Coroutine?",opts:["When you need to pass parameters","For simple one-off delays with no parameters","When the delay is under 1 second","Invoke is always better"],ans:1,explain:"Invoke is simpler for basic one-off delays (e.g. Invoke('Explode', 3f)). Use Coroutines when you need parameters, complex sequences, or loops."},
  {q:"A coroutine has <code>while(true)</code> and <code>yield return new WaitForSeconds(1f)</code>. What happens?",opts:["Infinite loop — crashes Unity","Runs once then stops","Repeats every 1 second indefinitely until StopCoroutine is called","Throws an exception after 10 iterations"],ans:2,explain:"while(true) with a yield is safe — the yield pauses execution, giving Unity control every second. This is a common pattern for repeating spawners, wave managers, etc. Stop it with StopCoroutine()."},
])}

