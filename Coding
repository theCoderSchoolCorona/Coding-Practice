{tier:3,icon:"🎮",name:"MonoBehaviour Lifecycle",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(52,211,153,0.1);color:#34d399">Tier 4 — Unity Core</div>
  <h1>🎮 MonoBehaviour &amp; The Lifecycle</h1>
  <p>Every Unity script inherits from MonoBehaviour. Unity calls specific methods at specific times — knowing the order is essential.</p>
  <div class="badges"><span class="badge unity">★ Awake</span><span class="badge unity">★ Start</span><span class="badge unity">★ Update</span><span class="badge unity">★ FixedUpdate</span><span class="badge unity">★ LateUpdate</span><span class="badge unity">★ OnDestroy</span></div>
</div>

<div class="section">
  <h2>🔄 Lifecycle Order</h2>
  <table class="ctable">
    <tr><th>Method</th><th>When</th><th>Use for</th><th>Frame?</th></tr>
    <tr><td><code>Awake()</code></td><td>Before Start, even if disabled</td><td>Getting component references, one-time setup</td><td>First frame only</td></tr>
    <tr><td><code>OnEnable()</code></td><td>When object/script enabled</td><td>Re-subscribing to events</td><td>On enable</td></tr>
    <tr><td><code>Start()</code></td><td>First frame, after all Awake</td><td>Using refs set up in Awake, starting coroutines</td><td>First frame only</td></tr>
    <tr><td><code>FixedUpdate()</code></td><td>Every physics step (~50/sec)</td><td>Physics — Rigidbody forces, AddForce</td><td>Fixed interval</td></tr>
    <tr><td><code>Update()</code></td><td>Every frame (varies with fps)</td><td>Input, movement (non-physics), timers</td><td>Every frame</td></tr>
    <tr><td><code>LateUpdate()</code></td><td>After all Updates</td><td>Camera — follow player position after it moved</td><td>Every frame</td></tr>
    <tr><td><code>OnDisable()</code></td><td>When disabled</td><td>Unsubscribing from events</td><td>On disable</td></tr>
    <tr><td><code>OnDestroy()</code></td><td>When destroyed</td><td>Cleanup, saving data</td><td>On destroy</td></tr>
  </table>
</div>

<div class="section">
  <h2>💻 Full Script Template</h2>
  <pre><span class="kw">using</span> UnityEngine;

<span class="kw">public class</span> <span class="ty">PlayerController</span> : <span class="uk">MonoBehaviour</span>
{
    <span class="cm">// [SerializeField] shows private fields in Inspector</span>
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">float</span> moveSpeed = <span class="num">5f</span>;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">int</span>   maxHealth = <span class="num">100</span>;

    <span class="kw">private</span> <span class="ty">int</span>        currentHealth;
    <span class="kw">private</span> <span class="ty">Rigidbody</span>  rb;
    <span class="kw">private</span> <span class="ty">Animator</span>   anim;

    <span class="kw">void</span> <span class="fn">Awake</span>()
    {
        <span class="cm">// Cache component references here</span>
        rb   = <span class="fn">GetComponent</span>&lt;<span class="ty">Rigidbody</span>&gt;();
        anim = <span class="fn">GetComponent</span>&lt;<span class="ty">Animator</span>&gt;();
    }

    <span class="kw">void</span> <span class="fn">Start</span>()
    {
        <span class="cm">// Initialise with values set in Awake</span>
        currentHealth = maxHealth;
        <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Player ready!"</span>);
    }

    <span class="kw">void</span> <span class="fn">Update</span>()
    {
        <span class="fn">HandleInput</span>();
        <span class="fn">UpdateTimers</span>();
    }

    <span class="kw">void</span> <span class="fn">FixedUpdate</span>()
    {
        <span class="fn">ApplyPhysics</span>();  <span class="cm">// all Rigidbody work goes here</span>
    }

    <span class="kw">void</span> <span class="fn">LateUpdate</span>()
    {
        <span class="cm">// Camera follow would go here</span>
    }

    <span class="kw">void</span> <span class="fn">OnDestroy</span>()
    {
        <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Player destroyed — cleaning up"</span>);
    }
}</pre>

  <div class="unity-box">🎮 <strong>Best practice:</strong> Cache component references in Awake() — calling GetComponent() in Update() every frame is expensive. Store the reference in a private field once, use it forever.</div>
  <div class="tip-box">💡 Use <code>[SerializeField] private</code> instead of <code>public</code> for fields you want in the Inspector. It keeps them private to other scripts but visible to you in the editor.</div>
</div>

${Q([
  {q:"You need code to run ONCE when the game starts. Which method do you use?",opts:["Update()","FixedUpdate()","Start()","Awake()"],ans:2,explain:"Start() runs once on the first frame the script is active. Awake() also runs once but before Start — use Awake for getting references, Start for using them."},
  {q:"You're applying a force to a Rigidbody. Which method should you use?",opts:["Update()","Start()","FixedUpdate()","LateUpdate()"],ans:2,explain:"Always apply Rigidbody forces in FixedUpdate(). It runs on a consistent physics timestep, keeping movement smooth and predictable regardless of frame rate."},
  {q:"Your camera script follows the player. It should go in which method?",opts:["Update()","Awake()","FixedUpdate()","LateUpdate()"],ans:3,explain:"LateUpdate() runs after all Update() calls. This ensures the player has already moved before the camera follows, preventing jitter."},
  {q:"What does <code>GetComponent&lt;Rigidbody&gt;()</code> do?",opts:["Creates a new Rigidbody component","Returns the Rigidbody attached to this GameObject","Removes the Rigidbody","Checks if a Rigidbody exists"],ans:1,explain:"GetComponent<T>() finds and returns the component of type T on this same GameObject. Returns null if not found."},
  {q:"What is the difference between <code>public float speed</code> and <code>[SerializeField] private float speed</code>?",opts:["No difference","public is visible in Inspector AND accessible by other scripts; SerializeField private is only visible in Inspector","SerializeField is faster","public is only for Unity built-ins"],ans:1,explain:"[SerializeField] private shows the field in the Inspector (so you can set it) while keeping it private (other scripts can't access it). public exposes it everywhere — generally too open."},
  {q:"When does <code>OnDestroy()</code> run?",opts:["Every frame","When the scene loads","When the GameObject is destroyed or the scene unloads","When the script is disabled"],ans:2,explain:"OnDestroy() runs when the GameObject is destroyed (Destroy() is called) or when the scene containing it is unloaded. Good for cleanup."},
])}

${FIB("Complete the player script lifecycle:",
`<span class="kw">public class</span> <span class="ty">Player</span> : ${blank('MonoBehaviour',12)}
{
    [<span class="uk">SerializeField</span>] ${blank('private',8)} <span class="ty">float</span> speed = <span class="num">5f</span>;
    <span class="kw">private</span> <span class="ty">Rigidbody</span> rb;

    <span class="kw">void</span> ${blank('Awake',6)}()
    {
        rb = ${blank('GetComponent',13)}&lt;<span class="ty">Rigidbody</span>&gt;();
    }

    <span class="kw">void</span> ${blank('Start',6)}()
    {
        <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Player ready!"</span>);
    }

    <span class="kw">void</span> ${blank('Update',7)}()
    {
        <span class="cm">// Input every frame</span>
    }
}`,
['MonoBehaviour','private','Awake','GetComponent','Start','Update'])}

${BUG(
  "This script is meant to cache the Rigidbody reference efficiently. Find the performance bug:",
  `public class PlayerMove : MonoBehaviour
{
    public float speed = 5f;

    void FixedUpdate()
    {
        Rigidbody rb = GetComponent<Rigidbody>();
        rb.MovePosition(rb.position + Vector3.forward * speed * Time.fixedDeltaTime);
