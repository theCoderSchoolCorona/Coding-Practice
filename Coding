  // Apply default size class
  inst.classList.add(PANEL_SIZES[currentPanelSize]);
}

// ═══════════════════════════════════════════════════════════════
// PYTHON SYNTAX HIGHLIGHTER — textarea + pre overlay
// ═══════════════════════════════════════════════════════════════
function escHtml(s){
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function highlightPython(code){
  var lines = code.split('\n');
  var out = [];
  for(var li=0;li<lines.length;li++){
    var line = lines[li];
    var result = '';
    var i = 0;
    while(i < line.length){
      var ch = line[i];
      // Comment
      if(ch==='#'){
        result += '<span class="hl-cm">'+escHtml(line.slice(i))+'</span>';
        i = line.length; continue;
      }
      // Triple-quoted string
      var t3 = line.slice(i,i+3);
      if(t3==='"""' || t3==="'''"){
        var end3 = line.indexOf(t3, i+3);
        if(end3===-1){
          result += '<span class="hl-str">'+escHtml(line.slice(i))+'</span>';
          i = line.length;
        } else {
          result += '<span class="hl-str">'+escHtml(line.slice(i,end3+3))+'</span>';
          i = end3+3;
        }
        continue;
      }
      // Single-quoted string
      if(ch==='"' || ch==="'"){
        var j=i+1;
        while(j<line.length){
          if(line[j]==='\\' && j+1<line.length){j+=2;continue;}
          if(line[j]===ch){j++;break;}
          j++;
        }
        result += '<span class="hl-str">'+escHtml(line.slice(i,j))+'</span>';
        i=j; continue;
      }
      // Number
      if(/[0-9]/.test(ch) && (i===0||!/\w/.test(line[i-1]))){
        var nm = line.slice(i).match(/^[0-9]+\.?[0-9]*/);
        if(nm){ result+='<span class="hl-num">'+nm[0]+'</span>'; i+=nm[0].length; continue; }
      }
      // Word
      if(/[a-zA-Z_]/.test(ch)){
        var wm = line.slice(i).match(/^[a-zA-Z_]\w*/);
        if(wm){
          var w = wm[0];
          var prevWord = (line.slice(0,i).trimEnd().match(/\b(\w+)\s*$/)||['',''])[1];
          var span = '';
          if(prevWord==='def'||prevWord==='class'){
            span = 'hl-def';
          } else if(/^(and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield)$/.test(w)){
            span = 'hl-kw';
          } else if(/^(abs|all|any|bin|bool|bytes|callable|chr|dict|dir|divmod|enumerate|eval|exec|filter|float|format|frozenset|getattr|globals|hasattr|hash|help|hex|id|input|int|isinstance|issubclass|iter|len|list|locals|map|max|min|next|object|oct|open|ord|pow|print|property|range|repr|reversed|round|set|setattr|slice|sorted|staticmethod|str|sum|super|tuple|type|vars|zip)$/.test(w)){
            span = 'hl-bi';
          } else if(/^(True|False|None)$/.test(w)){
            span = 'hl-at';
          }
          if(span) result+='<span class="'+span+'">'+escHtml(w)+'</span>';
          else     result+=escHtml(w);
          i+=w.length; continue;
        }
      }
      // Operator
      if(/[+\-*/%=<>!&|^~@]/.test(ch)){
        result+='<span class="hl-op">'+escHtml(ch)+'</span>'; i++; continue;
      }
      result+=escHtml(ch); i++;
    }
    out.push(result);
  }
  return out.join('\n');
}

function hlUpdate(){
  var pre = document.getElementById('hl-pre');
  var ed  = document.getElementById('ed');
  if(!pre||!ed) return;
  var code = ed.value;
  // Always append a space so trailing newlines render properly
  if(code.length === 0 || code[code.length-1]==='\n') code += ' ';
  pre.innerHTML = highlightPython(code);
  hlSyncScroll();
}

function hlSyncScroll(){
  var pre = document.getElementById('hl-pre');
  var ed  = document.getElementById('ed');
  if(!pre||!ed) return;
  pre.style.transform = 'translate(' + (-ed.scrollLeft) + 'px, ' + (-ed.scrollTop) + 'px)';
}

function initHighlight(){
  hlUpdate();
  var ed = document.getElementById('ed');
  if(!ed) return;
  // Use scroll event — keep pre in lockstep with textarea position
  ed.addEventListener('scroll', hlSyncScroll, {passive:true});
  // Also sync on these events in case scroll event doesn't fire
  ed.addEventListener('input',  hlSyncScroll);
  ed.addEventListener('click',  hlSyncScroll);
  ed.addEventListener('keyup',  hlSyncScroll);
}

// Tab key — called from onkeydown
function hlKey(e){
  if(e.key === 'Tab'){
    e.preventDefault();
    var ed = document.getElementById('ed');
    var s = ed.selectionStart;
    var v = ed.value;
    ed.value = v.slice(0,s) + '    ' + v.slice(ed.selectionEnd);
    ed.selectionStart = ed.selectionEnd = s + 4;
    hlUpdate();
  }
}

