}</pre>

  <table class="ctable" style="margin-top:10px">
    <tr><th>Operator</th><th>Meaning</th><th>Example</th><th>Result</th></tr>
    <tr><td><code>==</code></td><td>Equal to</td><td><code>score == 100</code></td><td>true if score is exactly 100</td></tr>
    <tr><td><code>!=</code></td><td>Not equal</td><td><code>name != "enemy"</code></td><td>true if name is anything but "enemy"</td></tr>
    <tr><td><code>&gt;</code></td><td>Greater than</td><td><code>health &gt; 0</code></td><td>true if health is 1 or more</td></tr>
    <tr><td><code>&lt;</code></td><td>Less than</td><td><code>lives &lt; 3</code></td><td>true if lives is 0, 1, or 2</td></tr>
    <tr><td><code>&gt;=</code></td><td>Greater than or equal</td><td><code>score &gt;= 100</code></td><td>true if score is 100 or more</td></tr>
