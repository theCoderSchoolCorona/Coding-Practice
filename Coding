<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>theCoderSchool Corona</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d0f1a;--panel:#141726;--panel2:#1c2035;--border:#252c47;--accent:#6ee7b7;--accent2:#818cf8;--text:#e2e8f0;--muted:#8892b0;--output-bg:#090b14;--error:#f87171;--success:#34d399;--warn:#fbbf24}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);height:100vh;display:flex;flex-direction:column;overflow:hidden}
header{background:var(--panel);border-bottom:1px solid var(--border);padding:0 20px;display:flex;align-items:stretch;height:48px;flex-shrink:0}
.logo-area{display:flex;align-items:center;padding-right:20px;border-right:1px solid var(--border)}
.logo{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--accent);white-space:nowrap}
.logo span{color:#f472b6}
.course-tabs{display:flex;align-items:stretch}
.ctab{background:transparent;border:none;border-right:1px solid var(--border);color:var(--muted);padding:0 22px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all 0.15s;font-family:'DM Sans',sans-serif;border-bottom:2px solid transparent}
.ctab:hover{color:var(--text);background:rgba(255,255,255,0.03)}
.ctab.py.active{color:#6ee7b7;border-bottom-color:#6ee7b7;background:rgba(110,231,183,0.05)}
.ctab.cs.active{color:#60a5fa;border-bottom-color:#60a5fa;background:rgba(96,165,250,0.05)}
.ctab.rb.active{color:#a78bfa;border-bottom-color:#a78bfa;background:rgba(167,139,250,0.05)}
.header-right{margin-left:auto;display:flex;align-items:center;padding-left:16px}
.py-status{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)}
.dot{width:7px;height:7px;border-radius:50%;background:#34d399}
.app-panel{display:flex;flex:1;overflow:hidden;position:relative}
.sidebar{width:215px;flex-shrink:0;background:#0a0b13;border-right:1px solid var(--border);overflow-y:auto}
.tier-label{padding:10px 14px 4px;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;border-top:1px solid var(--border);margin-top:4px}
.tier-label:first-child{border-top:none;margin-top:0}
.proj-tab{padding:7px 12px;font-size:12px;cursor:pointer;color:var(--muted);transition:all 0.15s;display:flex;align-items:center;gap:7px;border-left:3px solid transparent}
.proj-tab:hover{color:var(--text);background:rgba(255,255,255,0.03)}
.proj-tab.active{color:var(--accent);background:rgba(110,231,183,0.06);border-left-color:var(--accent)}
.proj-tab .num{font-family:'Space Mono',monospace;font-size:10px;min-width:18px;color:var(--muted)}
.proj-tab.active .num{color:var(--accent)}

*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0f1117;--panel:#1a1d27;--panel2:#21253a;--border:#2e3250;--accent:#6ee7b7;--accent2:#818cf8;--text:#e2e8f0;--muted:#8892b0;--output-bg:#0d1117;--error:#f87171;--success:#6ee7b7}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);height:100vh;display:flex;flex-direction:column;overflow:hidden}
header{background:var(--panel);border-bottom:1px solid var(--border);padding:10px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.logo{font-family:'Space Mono',monospace;font-size:15px;font-weight:700;color:var(--accent)}.logo span{color:var(--accent2)}
.subtitle{font-size:12px;color:var(--muted)}
.status{margin-left:auto;display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted)}
.dot{width:7px;height:7px;border-radius:50%;background:#f59e0b;animation:pulse 1.5s infinite}.dot.ready{background:var(--accent);animation:none}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
.main{display:flex;flex:1;overflow:hidden;position:relative}
.sidebar{width:215px;flex-shrink:0;background:#13151f;border-right:1px solid var(--border);overflow-y:auto}
.tier-label{padding:10px 14px 4px;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;border-top:1px solid var(--border);margin-top:4px}
.tier-label:first-child{border-top:none;margin-top:0}
.proj-tab{padding:7px 12px 7px 14px;font-size:12px;font-weight:500;cursor:pointer;color:var(--muted);transition:all 0.15s;display:flex;align-items:center;gap:7px;border-left:3px solid transparent}
.proj-tab:hover{color:var(--text);background:rgba(255,255,255,0.04)}
.proj-tab.active{color:var(--accent);background:rgba(110,231,183,0.07);border-left-color:var(--accent)}
.proj-tab .num{font-family:'Space Mono',monospace;font-size:10px;min-width:18px;color:var(--muted)}
.proj-tab.active .num{color:var(--accent)}
.inst{width:340px;background:var(--panel);border-right:1px solid var(--border);overflow-y:auto;padding:16px;transition:width 0.2s ease,flex-basis 0.2s ease}
.tier-pill{display:inline-block;font-size:10px;font-weight:600;padding:2px 9px;border-radius:20px;margin-bottom:7px}
.inst h2{font-size:17px;font-weight:600;color:var(--accent);margin-bottom:4px}
.meta{font-size:11px;margin-bottom:10px;display:flex;gap:5px;flex-wrap:wrap}
.badge{padding:2px 8px;border-radius:20px;font-size:11px}
.badge.new{background:rgba(251,191,36,0.15);color:#fbbf24}
.badge.rep{background:rgba(129,140,248,0.1);color:var(--accent2)}
.badge.def{background:rgba(110,231,183,0.1);color:var(--accent)}
.inst p{font-size:14px;line-height:1.6;color:#a8b2d8;margin-bottom:9px}
.inst h3{font-size:14px;font-weight:600;color:var(--text);margin:14px 0 5px;display:flex;align-items:center;gap:5px}
.concept-box{background:rgba(251,191,36,0.06);border:1px solid rgba(251,191,36,0.2);border-radius:8px;padding:11px;margin-bottom:9px}
.concept-box h4{font-size:11px;color:#fbbf24;margin-bottom:6px;font-weight:600}
.concept-line{margin-bottom:5px;font-size:11px;color:#c8b88a;line-height:1.6}
.concept-line code{background:rgba(0,0,0,0.35);padding:1px 5px;border-radius:3px;font-family:'Space Mono',monospace;font-size:10px;color:#fde68a}
.concept-line strong{color:#fbbf24}
.output-example{background:#0d1117;border:1px solid rgba(110,231,183,0.15);border-radius:8px;padding:10px;margin-bottom:9px;font-family:'Space Mono',monospace;font-size:11px;color:#6ee7b7;line-height:1.7}
.output-example .label{font-family:'DM Sans',sans-serif;font-size:10px;color:var(--muted);margin-bottom:5px;font-weight:600;letter-spacing:.5px}
.step{background:var(--panel2);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px}
.step-hdr{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.step-num{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;color:#0f1117}
.step-title{font-size:12px;font-weight:600;color:var(--text)}
.step-body{font-size:14px;line-height:1.6;color:#a8b2d8}
.step-body code{background:rgba(255,255,255,0.08);padding:1px 4px;border-radius:3px;font-family:'Space Mono',monospace;font-size:10px;color:var(--accent)}
.step-tip{margin-top:6px;background:rgba(110,231,183,0.06);border-left:2px solid var(--accent);padding:5px 8px;border-radius:0 5px 5px 0;font-size:11px;color:#6ee7b7}
.mistake-box{background:rgba(248,113,113,0.06);border:1px solid rgba(248,113,113,0.2);border-radius:8px;padding:10px;margin-bottom:9px}
.mistake-box h4{font-size:11px;color:#f87171;margin-bottom:6px;font-weight:600}
.mistake-item{font-size:11px;color:#fca5a5;margin-bottom:4px;padding-left:14px;position:relative;line-height:1.5}
.mistake-item::before{content:"✗";position:absolute;left:0;color:#f87171}
.mistake-item code{background:rgba(0,0,0,0.3);padding:1px 4px;border-radius:3px;font-family:'Space Mono',monospace;font-size:10px;color:#fca5a5}
.hint-box{background:rgba(129,140,248,0.07);border:1px solid rgba(129,140,248,0.2);border-radius:8px;padding:10px;margin-top:9px}
.hint-box h4{font-size:11px;color:var(--accent2);margin-bottom:5px;font-weight:600}
.hint-item{font-size:11px;color:#a8b2d8;margin-bottom:3px;padding-left:14px;position:relative;line-height:1.5}
.hint-item::before{content:"•";position:absolute;left:0;color:var(--accent2)}
.hint-item code{background:rgba(255,255,255,0.08);padding:1px 4px;border-radius:3px;font-family:'Space Mono',monospace;font-size:10px;color:var(--accent)}
.bonus-box{background:rgba(192,132,252,0.07);border:1px solid rgba(192,132,252,0.2);border-radius:8px;padding:10px;margin-top:9px}
.bonus-box h4{font-size:11px;color:#c084fc;margin-bottom:5px;font-weight:600}
.bonus-item{font-size:11px;color:#d8b4fe;margin-bottom:3px;padding-left:16px;position:relative;line-height:1.5}
.bonus-item::before{content:"⭐";position:absolute;left:0;font-size:9px;top:2px}
.editor-pane{flex:1;min-width:0;min-height:0;overflow:hidden;display:flex;flex-direction:column}
.editor-header{background:var(--panel);border-bottom:1px solid var(--border);padding:8px 14px;display:flex;align-items:center;gap:8px;flex-shrink:0}
.fname{font-family:'Space Mono',monospace;font-size:12px;color:var(--muted)}
.run-btn{margin-left:auto;background:var(--accent);color:#0f1117;border:none;padding:6px 16px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;transition:all 0.15s}
.run-btn:hover{background:#34d399;transform:translateY(-1px)}.run-btn:disabled{background:#2e3250;color:var(--muted);cursor:not-allowed;transform:none}
.ibtn{background:transparent;border:1px solid var(--border);color:var(--muted);padding:6px 11px;border-radius:6px;font-size:12px;cursor:pointer;transition:all 0.15s}
.ibtn:hover{border-color:var(--muted);color:var(--text)}.ibtn.d:hover{border-color:#f87171;color:#f87171}
textarea{flex:1;background:var(--output-bg);color:#cdd6f4;border:none;padding:16px;font-family:'Space Mono',monospace;font-size:13px;line-height:1.7;resize:none;outline:none;tab-size:4}
textarea::selection{background:rgba(110,231,183,0.2)}
.out-pane{height:160px;flex-shrink:0;border-top:1px solid var(--border);display:flex;flex-direction:column}
.out-hdr{background:var(--panel);padding:6px 14px;font-size:11px;color:var(--muted);font-family:'Space Mono',monospace;border-bottom:1px solid var(--border);flex-shrink:0}
.out-body{flex:1;overflow-y:auto;padding:8px 14px;font-family:'Space Mono',monospace;font-size:12px;line-height:1.8;background:var(--output-bg)}
.ol{color:#a8b2d8}.ol.err{color:var(--error)}.ol.ok{color:var(--success)}.ol.sys{color:var(--muted);font-style:italic}.ol.inp{color:#fbbf24}
.overlay{position:absolute;inset:0;background:rgba(15,17,23,0.88);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;z-index:10}
.overlay p{font-size:13px;color:var(--muted)}
.spin{width:26px;height:26px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}


*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d0f1a;--panel:#141726;--panel2:#1c2035;--border:#252c47;--accent:#60a5fa;--accent2:#a78bfa;--accent3:#34d399;--text:#e2e8f0;--muted:#8892b0;--error:#f87171;--success:#34d399;--warn:#fbbf24}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);height:100vh;display:flex;flex-direction:column;overflow:hidden}
header{background:var(--panel);border-bottom:1px solid var(--border);padding:10px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.logo{font-family:'Space Mono',monospace;font-size:15px;font-weight:700;color:var(--accent)}.logo span{color:var(--accent2)}
.subtitle{font-size:12px;color:var(--muted)}
.hbadge{margin-left:auto;background:rgba(96,165,250,0.12);border:1px solid rgba(96,165,250,0.3);color:var(--accent);padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600}
.main{display:flex;flex:1;overflow:hidden}
.sidebar{width:215px;flex-shrink:0;background:#0a0c14;border-right:1px solid var(--border);overflow-y:auto}
.tier-label{padding:10px 14px 4px;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;border-top:1px solid var(--border);margin-top:4px}
.tier-label:first-child{border-top:none;margin-top:0}
.proj-tab{padding:7px 12px;font-size:12px;cursor:pointer;color:var(--muted);transition:all 0.15s;display:flex;align-items:center;gap:7px;border-left:3px solid transparent}
.proj-tab:hover{color:var(--text);background:rgba(255,255,255,0.03)}
.proj-tab.active{color:var(--accent);background:rgba(96,165,250,0.07);border-left-color:var(--accent)}
.proj-tab .num{font-family:'Space Mono',monospace;font-size:10px;min-width:18px;color:var(--muted)}
.proj-tab.active .num{color:var(--accent)}
.content{flex:1;overflow-y:auto;background:var(--bg)}
.page{max-width:860px;margin:0 auto;padding:24px}

.lesson-header{margin-bottom:20px}
.tier-pill{display:inline-block;font-size:10px;font-weight:600;padding:2px 10px;border-radius:20px;margin-bottom:8px}
.lesson-header h1{font-size:20px;font-weight:600;color:var(--accent);margin-bottom:5px}
.lesson-header p{font-size:13px;color:var(--muted);line-height:1.6}
.badges{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
.badge{padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600}
.badge.new{background:rgba(251,191,36,0.15);color:#fbbf24}
.badge.unity{background:rgba(96,165,250,0.12);color:var(--accent)}
.badge.rep{background:rgba(167,139,250,0.12);color:var(--accent2)}

.section{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:14px}
.section h2{font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;display:flex;align-items:center;gap:7px}
.section p{font-size:13px;color:#a8b2d8;line-height:1.6;margin-bottom:10px}
.section p:last-child{margin-bottom:0}

pre{background:#090b14;border:1px solid var(--border);border-radius:8px;padding:14px;font-family:'Space Mono',monospace;font-size:12px;line-height:1.9;overflow-x:auto;margin:10px 0;white-space:pre-wrap}
.kw{color:#c084fc}.ty{color:#60a5fa}.str{color:#86efac}.num{color:#fb923c}.cm{color:#4b5563;font-style:italic}.fn{color:#fde68a}.uk{color:#34d399}

.ctable{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
.ctable th{background:var(--panel2);padding:7px 10px;text-align:left;font-weight:600;color:var(--muted);font-size:11px;border-bottom:1px solid var(--border)}
.ctable td{padding:7px 10px;border-bottom:1px solid rgba(37,44,71,0.5);vertical-align:top;color:#a8b2d8;font-size:12px}
.ctable td code,.ctable th code{background:rgba(255,255,255,0.06);padding:1px 5px;border-radius:3px;font-family:'Space Mono',monospace;font-size:11px;color:var(--accent)}
.ctable tr:last-child td{border-bottom:none}

.compare{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:10px 0}
.compare-box{background:#090b14;border:1px solid var(--border);border-radius:8px;padding:12px}
.compare-box .clabel{font-size:10px;font-weight:600;margin-bottom:6px;letter-spacing:.5px}
.compare-box pre{background:none;border:none;padding:0;margin:0;font-size:11px}

.tip-box{background:rgba(52,211,153,0.06);border-left:3px solid var(--success);border-radius:0 8px 8px 0;padding:10px 12px;margin:10px 0;font-size:12px;color:#a7f3d0;line-height:1.6}
.note-box{background:rgba(251,191,36,0.06);border-left:3px solid var(--warn);border-radius:0 8px 8px 0;padding:10px 12px;margin:10px 0;font-size:12px;color:#fde68a;line-height:1.6}
.unity-box{background:rgba(96,165,250,0.06);border-left:3px solid var(--accent);border-radius:0 8px 8px 0;padding:10px 12px;margin:10px 0;font-size:12px;color:#bfdbfe;line-height:1.6}

.mistake-box{background:rgba(248,113,113,0.05);border:1px solid rgba(248,113,113,0.2);border-radius:10px;padding:14px;margin-top:12px}
.mistake-box h3{font-size:12px;color:#f87171;margin-bottom:10px;font-weight:600}
.mistake-item{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid rgba(248,113,113,0.1)}
.mistake-item:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.ml{font-size:10px;font-weight:700;margin-bottom:5px;letter-spacing:.5px}
.ml.bad{color:#f87171}.ml.good{color:#86efac}
.wrong-code{color:#fca5a5;font-size:11px;font-family:'Space Mono',monospace;line-height:1.7}
.right-code{color:#86efac;font-size:11px;font-family:'Space Mono',monospace;line-height:1.7}

/* QUIZ */
.quiz-section{background:var(--panel);border:1px solid rgba(96,165,250,0.25);border-radius:12px;padding:18px;margin-bottom:14px}
.quiz-section h2{font-size:14px;font-weight:600;color:var(--accent);margin-bottom:14px;display:flex;align-items:center;gap:7px}
.qscore{font-size:11px;color:var(--muted);margin-left:auto;font-weight:500}
.q-item{background:var(--panel2);border:1px solid var(--border);border-radius:8px;padding:13px;margin-bottom:9px}
.q-item:last-child{margin-bottom:0}
.q-text{font-size:13px;font-weight:500;color:var(--text);margin-bottom:10px;line-height:1.55}
.q-text code{background:rgba(255,255,255,0.08);padding:1px 5px;border-radius:3px;font-family:'Space Mono',monospace;font-size:12px;color:var(--accent)}
.options{display:flex;flex-direction:column;gap:5px}
.opt{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-size:12px;cursor:pointer;transition:all 0.15s;color:var(--muted);display:flex;align-items:center;gap:8px;user-select:none}
.opt:hover{border-color:var(--accent);color:var(--text)}
.opt.selected{border-color:var(--accent);color:var(--text);background:rgba(96,165,250,0.07)}
.opt.correct{border-color:var(--success)!important;color:var(--success)!important;background:rgba(52,211,153,0.08)!important}
.opt.wrong{border-color:var(--error)!important;color:var(--error)!important;background:rgba(248,113,113,0.07)!important}
.opt-marker{width:18px;height:18px;border-radius:50%;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;font-weight:700}
.q-feedback{margin-top:8px;font-size:12px;padding:7px 10px;border-radius:6px;display:none;line-height:1.5}
.q-feedback.show{display:block}
.q-feedback.ok{background:rgba(52,211,153,0.08);border:1px solid rgba(52,211,153,0.2);color:#86efac}
.q-feedback.bad{background:rgba(248,113,113,0.07);border:1px solid rgba(248,113,113,0.2);color:#fca5a5}

/* FILL IN BLANK */
.fib-section{background:var(--panel);border:1px solid rgba(167,139,250,0.25);border-radius:12px;padding:18px;margin-bottom:14px}
.fib-section h2{font-size:14px;font-weight:600;color:var(--accent2);margin-bottom:6px;display:flex;align-items:center;gap:7px}
.fib-section .fibdesc{font-size:12px;color:var(--muted);margin-bottom:10px}
.fib-code{background:#090b14;border:1px solid var(--border);border-radius:8px;padding:14px;font-family:'Space Mono',monospace;font-size:12px;line-height:2.2;margin-bottom:10px;overflow-x:auto}
.blank{display:inline-block;background:rgba(167,139,250,0.1);border:1px dashed rgba(167,139,250,0.5);border-radius:4px;padding:1px 6px;font-family:'Space Mono',monospace;font-size:12px;color:var(--accent2);outline:none;vertical-align:middle;min-width:60px}
.blank:focus{border-color:var(--accent2);background:rgba(167,139,250,0.15)}
.blank.correct{border-color:var(--success)!important;background:rgba(52,211,153,0.1)!important;color:var(--success)!important;border-style:solid!important}
.blank.wrong{border-color:var(--error)!important;background:rgba(248,113,113,0.08)!important;color:#f87171!important;border-style:solid!important}
.fib-btns{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:6px}
.check-btn{background:var(--accent2);color:#0d0f1a;border:none;padding:7px 18px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s}
.check-btn:hover{background:#c4b5fd}
