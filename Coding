,{tier:4,icon:"✨",name:"TweenService",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(52,211,153,0.1);color:#34d399">Tier 5 — Roblox Gameplay</div>
  <h1>✨ TweenService</h1>
  <p>Smoothly animate any property of any Instance over time. Move doors, fade colours, resize objects — all with a few lines of code.</p>
  <div class="badges"><span class="badge rb">★ TweenService</span><span class="badge rb">★ TweenInfo</span><span class="badge rb">★ Enum.EasingStyle</span><span class="badge rb">★ :Play()/:Cancel()</span></div>
</div>
<div class="section">
  <h2>💻 Basic Tween</h2>
  <pre><span class="kw">local</span> TweenService = game:GetService(<span class="str">"TweenService"</span>)
<span class="kw">local</span> part = workspace.Door

<span class="cm">-- TweenInfo: (time, easingStyle, easingDirection, repeatCount, reverses, delayTime)</span>
<span class="kw">local</span> tweenInfo = TweenInfo.<span class="fn">new</span>(
    <span class="num">1.5</span>,                           <span class="cm">-- duration in seconds</span>
    Enum.EasingStyle.Quad,        <span class="cm">-- easing curve</span>
    Enum.EasingDirection.Out,     <span class="cm">-- In / Out / InOut</span>
    <span class="num">0</span>,                             <span class="cm">-- repeat count (0 = play once)</span>
    <span class="kw">false</span>,                         <span class="cm">-- reverses when done</span>
    <span class="num">0</span>                              <span class="cm">-- delay before starting</span>
)

<span class="cm">-- Goal: the final state you want</span>
<span class="kw">local</span> goal = {
    Position = Vector3.<span class="fn">new</span>(<span class="num">0</span>, <span class="num">10</span>, <span class="num">0</span>),
    Transparency = <span class="num">0.8</span>
}

<span class="cm">-- Create and play</span>
<span class="kw">local</span> tween = TweenService:<span class="fn">Create</span>(part, tweenInfo, goal)
tween:<span class="fn">Play</span>()

<span class="cm">-- Wait for tween to finish</span>
tween.Completed:<span class="fn">Wait</span>()
<span class="rb">print</span>(<span class="str">"Tween done!"</span>)</pre>
</div>
<div class="section">
  <h2>🎮 Common Tween Patterns</h2>
  <pre><span class="cm">-- ── Sliding door ──</span>
<span class="kw">local function</span> <span class="fn">openDoor</span>(door)
    <span class="kw">local</span> info = TweenInfo.<span class="fn">new</span>(<span class="num">0.5</span>, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    <span class="kw">local</span> open = { Position = door.Position + Vector3.<span class="fn">new</span>(<span class="num">0</span>, <span class="num">6</span>, <span class="num">0</span>) }
    TweenService:<span class="fn">Create</span>(door, info, open):<span class="fn">Play</span>()
<span class="kw">end</span>

<span class="cm">-- ── Colour flash (hit feedback) ──</span>
<span class="kw">local function</span> <span class="fn">flashRed</span>(part)
    <span class="kw">local</span> info     = TweenInfo.<span class="fn">new</span>(<span class="num">0.1</span>, Enum.EasingStyle.Linear, Enum.EasingDirection.In, <span class="num">0</span>, <span class="kw">true</span>)
    <span class="kw">local</span> redGoal  = { Color = Color3.<span class="fn">fromRGB</span>(<span class="num">255</span>, <span class="num">0</span>, <span class="num">0</span>) }
    TweenService:<span class="fn">Create</span>(part, info, redGoal):<span class="fn">Play</span>()   <span class="cm">-- reverses = back to original</span>
<span class="kw">end</span>

<span class="cm">-- ── Coin bounce + fade ──</span>
<span class="kw">local function</span> <span class="fn">collectCoin</span>(coin)
    <span class="kw">local</span> info = TweenInfo.<span class="fn">new</span>(<span class="num">0.3</span>, Enum.EasingStyle.Back, Enum.EasingDirection.In)
    <span class="kw">local</span> goal = {
        Position    = coin.Position + Vector3.<span class="fn">new</span>(<span class="num">0</span>, <span class="num">3</span>, <span class="num">0</span>),
        Transparency = <span class="num">1</span>,
        Size        = Vector3.<span class="fn">new</span>(<span class="num">0</span>, <span class="num">0</span>, <span class="num">0</span>)
    }
    <span class="kw">local</span> tween = TweenService:<span class="fn">Create</span>(coin, info, goal)
    tween:<span class="fn">Play</span>()
    tween.Completed:<span class="fn">Connect</span>(<span class="kw">function</span>()
        coin:<span class="fn">Destroy</span>()
    <span class="kw">end</span>)
<span class="kw">end</span></pre>
  <div class="rb-box">🟦 <strong>EasingStyle guide:</strong> Quad/Sine = smooth generic. Back = slight overshoot (bouncy). Bounce = bounces at end. Elastic = spring-like. Linear = no easing. Most UIs use Sine or Quad Out.</div>
</div>
${Q([
  {q:"What does the <code>reverses</code> parameter in TweenInfo do?",opts:["Plays the tween backwards from the start","After reaching the goal, automatically animates back to the start value","Reverses the easing direction","Plays the tween twice"],ans:1,explain:"When reverses = true, the tween plays forward to the goal then plays backward to the original value. Great for a flash effect (red → back to white) without writing two separate tweens."},
  {q:"What type does the <code>goal</code> table contain?",opts:["Anything","The target Instance","Property names and their desired final values","Only Vector3 values"],ans:2,explain:"The goal is a table of property names (as strings) mapped to their target values. Any tweenable property works: Position, Size, Color, Transparency, CFrame, etc."},
  {q:"How do you wait for a tween to finish before running the next code?",opts:["task.wait(tweenInfo.Time)","tween.Completed:Wait()","tween:Pause()","tween.IsPlaying == false"],ans:1,explain:"tween.Completed is an event that fires when the tween finishes. :Wait() yields until it fires. Using task.wait() with a hardcoded time is fragile — the tween could be cancelled or take different time."},
  {q:"What EasingStyle would you use for a bouncy UI popup?",opts:["Linear","Quad","Back or Bounce","Sine"],ans:2,explain:"Back (slight overshoot then settle) or Bounce (bounces at the end) give a bouncy, playful feel. Linear is mechanical, Sine is smooth but unremarkable for UI."},
])}
${FIB("Complete the door open/close tween:",
`<span class="kw">local</span> TS = game:GetService(${blank('"TweenService"',15)})
<span class="kw">local</span> door = workspace.Door
<span class="kw">local</span> isOpen = <span class="kw">false</span>

<span class="kw">local</span> info = TweenInfo.${blank('new',4)}(
    ${blank('0.8',4)}, Enum.EasingStyle.${blank('Sine',5)},
    Enum.EasingDirection.Out
)

<span class="kw">local function</span> toggleDoor()
    isOpen = ${blank('not',4)} isOpen
    <span class="kw">local</span> goal = {
        CFrame = isOpen
            <span class="kw">and</span> door.CFrame + Vector3.new(<span class="num">0</span>, <span class="num">8</span>, <span class="num">0</span>)
            <span class="kw">or</span>  door.CFrame - Vector3.new(<span class="num">0</span>, <span class="num">8</span>, <span class="num">0</span>)
    }
    TS:${blank('Create',7)}(door, info, goal):${blank('Play',5)}()
<span class="kw">end</span>`,
['"TweenService"','new','Sine','not','Create','Play'])}
${CHALLENGES([
  "Create a floating coin animation: infinite loop tween that moves the coin up 1 stud and reverses.",
  "Build a spawn-in effect: new part starts at scale 0 and tweens to full size over 0.5 seconds.",
  "Make a traffic light: tween BrickColor through red → yellow → green on a timer loop.",
  "Create a screen shake effect by tweening the camera's CFrame with small random offsets.",
  "Build a health bar UI: tween the Size.X of a Frame to represent current / max health.",
])}
`}

// ════ NEW ROBLOX: DATA STORES ═════════════════════════════════
,{tier:4,icon:"💾",name:"DataStores",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(52,211,153,0.1);color:#34d399">Tier 5 — Roblox Gameplay</div>
  <h1>💾 DataStores — Saving Player Data</h1>
  <p>DataStores save player data permanently so coins, level, and progress persist between sessions. Every serious Roblox game needs them.</p>
  <div class="badges"><span class="badge rb">★ DataStoreService</span><span class="badge rb">★ GetAsync/SetAsync</span><span class="badge rb">★ pcall</span><span class="badge rb">★ PlayerRemoving</span></div>
</div>
<div class="section">
  <h2>⚠️ Critical Rules</h2>
  <table class="ctable">
    <tr><th>Rule</th><th>Why</th></tr>
    <tr><td>Always use <code>pcall()</code></td><td>DataStore calls can fail — pcall prevents crashes</td></tr>
    <tr><td>Save on <code>PlayerRemoving</code></td><td>Save when the player leaves, not every second</td></tr>
    <tr><td>Test in Studio with API access enabled</td><td>DataStores require "Enable Studio Access" in Game Settings</td></tr>
    <tr><td>Never trust the client</td><td>All DataStore calls must be in a server Script</td></tr>
  </table>
  <div class="note-box">⚠️ DataStores only work in published games or with Studio API access enabled (Game Settings → Security → Enable Studio Access to API Services).</div>
</div>
<div class="section">
  <h2>💻 Complete Save/Load System</h2>
  <pre><span class="cm">-- SERVER SCRIPT in ServerScriptService</span>
<span class="kw">local</span> DataStoreService = game:GetService(<span class="str">"DataStoreService"</span>)
<span class="kw">local</span> Players          = game:GetService(<span class="str">"Players"</span>)

<span class="kw">local</span> playerData = DataStoreService:<span class="fn">GetDataStore</span>(<span class="str">"PlayerData_v1"</span>)

<span class="cm">-- Default data for new players</span>
<span class="kw">local</span> DEFAULT_DATA = {
    coins  = <span class="num">0</span>,
    level  = <span class="num">1</span>,
    wins   = <span class="num">0</span>,
}

<span class="cm">-- Load data when player joins</span>
<span class="kw">local function</span> <span class="fn">loadData</span>(player)
    <span class="kw">local</span> key = <span class="str">"Player_"</span> .. player.UserId

    <span class="kw">local</span> success, data = <span class="fn">pcall</span>(<span class="kw">function</span>()
        <span class="kw">return</span> playerData:<span class="fn">GetAsync</span>(key)
    <span class="kw">end</span>)

    <span class="kw">if</span> success <span class="kw">then</span>
        data = data <span class="kw">or</span> DEFAULT_DATA   <span class="cm">-- nil = new player, use defaults</span>
        <span class="rb">print</span>(<span class="str">"Loaded data for "</span> .. player.Name)
    <span class="kw">else</span>
        data = DEFAULT_DATA            <span class="cm">-- load failed, use defaults</span>
        <span class="fn">warn</span>(<span class="str">"Failed to load data for "</span> .. player.Name)
    <span class="kw">end</span>

    <span class="cm">-- Create leaderstats from loaded data</span>
    <span class="kw">local</span> ls = Instance.<span class="fn">new</span>(<span class="str">"Folder"</span>)
    ls.Name   = <span class="str">"leaderstats"</span>
    ls.Parent = player

    <span class="kw">local</span> coins = Instance.<span class="fn">new</span>(<span class="str">"IntValue"</span>)
    coins.Name   = <span class="str">"Coins"</span>
    coins.Value  = data.coins
    coins.Parent = ls
<span class="kw">end</span>

<span class="cm">-- Save data when player leaves</span>
<span class="kw">local function</span> <span class="fn">saveData</span>(player)
    <span class="kw">local</span> key = <span class="str">"Player_"</span> .. player.UserId
    <span class="kw">local</span> ls  = player:FindFirstChild(<span class="str">"leaderstats"</span>)
    <span class="kw">if not</span> ls <span class="kw">then return end</span>

    <span class="kw">local</span> data = {
        coins = ls.Coins.Value,
        level = ls.Level.Value,
        wins  = ls.Wins.Value,
    }

    <span class="kw">local</span> success, err = <span class="fn">pcall</span>(<span class="kw">function</span>()
        playerData:<span class="fn">SetAsync</span>(key, data)
    <span class="kw">end</span>)

    <span class="kw">if</span> success <span class="kw">then</span>
        <span class="rb">print</span>(<span class="str">"Saved data for "</span> .. player.Name)
    <span class="kw">else</span>
        <span class="fn">warn</span>(<span class="str">"Save failed: "</span> .. tostring(err))
    <span class="kw">end</span>
<span class="kw">end</span>

<span class="cm">-- Connect events</span>
Players.PlayerAdded:<span class="fn">Connect</span>(<span class="fn">loadData</span>)
Players.PlayerRemoving:<span class="fn">Connect</span>(<span class="fn">saveData</span>)

<span class="cm">-- Also save if server shuts down unexpectedly</span>
game:BindToClose(<span class="kw">function</span>()
    <span class="kw">for</span> _, player <span class="kw">in</span> <span class="fn">ipairs</span>(Players:<span class="fn">GetPlayers</span>()) <span class="kw">do</span>
        <span class="fn">saveData</span>(player)
    <span class="kw">end</span>
<span class="kw">end</span>)</pre>
  <div class="rb-box">🟦 <strong>Key naming tip:</strong> Use <code>"Player_" .. player.UserId</code> not <code>player.Name</code>. Players can change their names but UserId never changes.</div>
</div>
${Q([
  {q:"Why must DataStore calls be wrapped in <code>pcall()</code>?",opts:["pcall makes them faster","DataStore calls can fail (network errors, rate limits) — pcall prevents a crash","Roblox requires it by their ToS","It makes the data save faster"],ans:1,explain:"pcall (protected call) catches errors instead of crashing the script. DataStore can fail due to network issues, rate limits, or Roblox outages. Without pcall, one failure crashes the entire script."},
  {q:"What key should you use to save a player's data?",opts:["player.Name","player.UserId","player.DisplayName","A random UUID"],ans:1,explain:"Always use player.UserId — a unique permanent number. player.Name can be changed by the player, which would break their save data."},
  {q:"A new player joins and GetAsync returns nil. What should you do?",opts:["Error out","Use default data with 'data = data or DEFAULT_DATA'","Try again 3 times","Give them 0 for everything"],ans:1,explain:"nil from GetAsync means no data exists yet (new player). The 'or DEFAULT_DATA' pattern handles this cleanly — use defaults when there's nothing saved yet."},
  {q:"When should you save player data?",opts:["Every second","Every time a value changes","When PlayerRemoving fires (and in BindToClose for server shutdown)","Only when the player asks"],ans:2,explain:"Save on PlayerRemoving (player leaving) and in game:BindToClose() (server shutting down). Saving every second hits rate limits. Saving on every change is wasteful — batch saves are better."},
  {q:"Where must DataStore code run?",opts:["LocalScript","ModuleScript","Server Script (Script)","Anywhere"],ans:2,explain:"DataStores can only be accessed from server scripts. LocalScripts don't have server permission. All save/load logic must be in a Script in ServerScriptService."},
])}
${FIB("Complete the save/load system:",
`<span class="kw">local</span> DSS     = game:GetService(${blank('"DataStoreService"',18)})
<span class="kw">local</span> store   = DSS:${blank('GetDataStore',13)}(<span class="str">"GameData_v1"</span>)

<span class="kw">local function</span> loadPlayer(player)
    <span class="kw">local</span> key = <span class="str">"Player_"</span> .. player.${blank('UserId',7)}
    <span class="kw">local</span> ok, data = ${blank('pcall',6)}(<span class="kw">function</span>()
        <span class="kw">return</span> store:${blank('GetAsync',9)}(key)
    <span class="kw">end</span>)
    <span class="kw">if</span> ok <span class="kw">then</span>
        data = data <span class="kw">or</span> {coins = <span class="num">0</span>, level = <span class="num">1</span>}
    <span class="kw">end</span>
<span class="kw">end</span>

<span class="kw">local function</span> savePlayer(player)
    <span class="kw">local</span> key  = <span class="str">"Player_"</span> .. player.UserId
    <span class="kw">local</span> data = {coins = player.leaderstats.Coins.Value}
    <span class="kw">local</span> ok, err = pcall(<span class="kw">function</span>()
        store:${blank('SetAsync',9)}(key, data)
    <span class="kw">end</span>)
    <span class="kw">if not</span> ok <span class="kw">then</span> warn(err) <span class="kw">end</span>
<span class="kw">end</span>

game:${blank('BindToClose',11)}(<span class="kw">function</span>()
    <span class="kw">for</span> _, p <span class="kw">in</span> ipairs(game.Players:GetPlayers()) <span class="kw">do</span>
        savePlayer(p)
    <span class="kw">end</span>
<span class="kw">end</span>)`,
['"DataStoreService"','GetDataStore','UserId','pcall','GetAsync','SetAsync','BindToClose'])}
${CHALLENGES([
  "Add an UpdateAsync call instead of SetAsync to safely handle concurrent edits.",
  "Save an inventory (table of item names) alongside coins and level.",
  "Add a 'times played' counter that increments every time the player joins.",
  "Create a global leaderboard using an OrderedDataStore that shows the top 10 coin earners.",
  "Implement a version migration: if saved data is old format (no 'wins' key), add a default value.",
])}
`}

