    }
    <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Wave complete!"</span>);
}

<span class="kw">void</span> <span class="fn">Start</span>()
{
    ${blank('StartCoroutine',15)}(${blank('SpawnWave',10)}(<span class="num">5</span>));
