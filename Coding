{tier:4,icon:"🔊",name:"Audio & Sound",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(244,114,182,0.1);color:#f472b6">Tier 5 — Unity Gameplay</div>
  <h1>🔊 Audio &amp; Sound</h1>
  <p>Add sound effects and music using AudioSource and AudioClip. Sound is one of the most impactful things you can add to a game.</p>
  <div class="badges"><span class="badge unity">★ AudioSource</span><span class="badge unity">★ AudioClip</span><span class="badge unity">★ PlayOneShot</span><span class="badge unity">★ AudioListener</span></div>
</div>
<div class="section">
  <h2>🧠 Audio Setup Reference</h2>
  <table class="ctable">
    <tr><th>Component</th><th>Where</th><th>Role</th></tr>
    <tr><td><code>AudioListener</code></td><td>Main Camera (added by default)</td><td>"Ears" — only one per scene</td></tr>
    <tr><td><code>AudioSource</code></td><td>Any GameObject that makes sound</td><td>Plays AudioClips</td></tr>
    <tr><td><code>AudioClip</code></td><td>Project assets (.mp3/.wav/.ogg)</td><td>The actual sound data</td></tr>
  </table>
</div>
<div class="section">
  <h2>💻 Playing Sounds in Code</h2>
  <pre><span class="kw">using</span> UnityEngine;

<span class="kw">public class</span> <span class="ty">SoundManager</span> : <span class="uk">MonoBehaviour</span>
{
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">AudioSource</span> audioSource;

    <span class="cm">// Assign clips in Inspector</span>
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">AudioClip</span> jumpSound;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">AudioClip</span> coinSound;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">AudioClip</span> deathSound;

    <span class="cm">// Play a one-shot sound (doesn't interrupt other sounds)</span>
    <span class="kw">public void</span> <span class="fn">PlayJump</span>()
    {
        audioSource.<span class="fn">PlayOneShot</span>(jumpSound);
    }

    <span class="cm">// Play and stop background music</span>
    <span class="kw">public void</span> <span class="fn">PlayMusic</span>(<span class="ty">AudioClip</span> music, <span class="ty">bool</span> loop = <span class="kw">true</span>)
    {
        audioSource.clip   = music;
        audioSource.loop   = loop;
        audioSource.volume = <span class="num">0.5f</span>;
        audioSource.<span class="fn">Play</span>();
    }

    <span class="cm">// Play with pitch variation (random pitch = less repetitive)</span>
    <span class="kw">public void</span> <span class="fn">PlayCoin</span>()
    {
        audioSource.pitch = <span class="uk">Random</span>.<span class="fn">Range</span>(<span class="num">0.9f</span>, <span class="num">1.1f</span>);
        audioSource.<span class="fn">PlayOneShot</span>(coinSound);
    }

    <span class="cm">// Quick static helper: play at world position</span>
    <span class="kw">public static void</span> <span class="fn">PlayAt</span>(<span class="ty">AudioClip</span> clip, <span class="ty">Vector3</span> position)
    {
        <span class="uk">AudioSource</span>.<span class="fn">PlayClipAtPoint</span>(clip, position);
    }
}

<span class="cm">// Singleton access pattern from other scripts:</span>
<span class="cm">// FindObjectOfType&lt;SoundManager&gt;().PlayJump();</span></pre>
  <div class="unity-box">🎮 <strong>PlayOneShot vs Play:</strong> Use <code>PlayOneShot</code> for sound effects — it plays the clip without interrupting anything else. Use <code>Play()</code> for background music. Multiple PlayOneShot calls overlap cleanly.</div>
  <div class="tip-box">💡 Add slight random pitch variation (<code>Random.Range(0.9f, 1.1f)</code>) to footsteps, coin pickups, or hits — it makes repeated sounds feel much less robotic.</div>
</div>
${Q([
  {q:"You want to play a coin pickup sound WITHOUT stopping the background music. Which method do you use?",opts:["audioSource.Play()","audioSource.PlayOneShot(coinClip)","AudioSource.PlayClipAtPoint()","audioSource.Stop()"],ans:1,explain:"PlayOneShot plays a clip overlapping with whatever else is playing. Play() stops the current clip and plays a new one, which would interrupt your music."},
  {q:"There should only be one of which component per scene?",opts:["AudioSource","AudioClip","AudioListener","AudioMixer"],ans:2,explain:"AudioListener is the 'ears' of the scene — Unity uses it to determine how sounds are heard spatially. There should only be one, usually on the Main Camera."},
  {q:"How do you make background music loop?",opts:["audioSource.PlayOneShot(clip, true)","audioSource.loop = true; audioSource.Play()","audioSource.Repeat()","Set loop in the AudioClip settings only"],ans:1,explain:"Set audioSource.loop = true then call audioSource.Play(). The audio source will restart the clip automatically when it ends."},
  {q:"What does <code>AudioSource.PlayClipAtPoint(clip, position)</code> do?",opts:["Plays the clip on the existing AudioSource","Creates a temporary GameObject with an AudioSource at that world position","Plays the clip panned to that position","Teleports the AudioSource"],ans:1,explain:"PlayClipAtPoint is a static helper that creates a temporary GameObject at the given position, plays the clip with 3D spatialization, then destroys itself. Good for explosion or impact sounds."},
])}
${FIB("Complete the sound effects manager:",
`[<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">AudioSource</span> ${blank('audioSource',12)};
[SerializeField] private AudioClip jumpClip, coinClip;

<span class="kw">public void</span> <span class="fn">PlayJump</span>()
{
    audioSource.${blank('PlayOneShot',12)}(jumpClip);
}

<span class="kw">public void</span> <span class="fn">PlayCoin</span>()
{
    audioSource.pitch = Random.${blank('Range',6)}(<span class="num">0.9f</span>, <span class="num">1.1f</span>);
    audioSource.${blank('PlayOneShot',12)}(${blank('coinClip',9)});
    audioSource.pitch = ${blank('1f',3)};  <span class="cm">// reset pitch</span>
