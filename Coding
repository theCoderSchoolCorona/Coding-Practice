function md(s){
  return s.replace(/\n/g,'<br>')
          .replace(/`([^`]+)`/g,'<code>$1</code>')
          .replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
}

function renderPYInst(idx){
  const p=P[idx], tier=T[p.tier];
  const badges=p.badges.map(b=>`<span class="badge ${b.k}">${b.k==='new'?'★ ':'↺ '}${b.l}</span>`).join('');

  const conceptHTML=p.concept?`
    <div class="concept-box">
      <h4>🧠 ${p.concept.title}</h4>
      ${p.concept.lines.map(l=>`<div class="concept-line">${md(l)}</div>`).join('')}
    </div>`:'';

  const expectedHTML=p.expected?`
    <div class="output-example">
      <div class="label">EXPECTED OUTPUT (EXAMPLE)</div>
      ${p.expected.split('\n').map(l=>`<div>${l}</div>`).join('')}
    </div>`:'';

  const stepsHTML=p.steps.map(s=>`
    <div class="step">
      <div class="step-hdr">
        <div class="step-num" style="background:${tier.color}">${s.n}</div>
        <div class="step-title">${s.t}</div>
      </div>
      <div class="step-body">${md(s.b)}${s.tip?`<div class="step-tip">💡 ${s.tip}</div>`:''}</div>
    </div>`).join('');

  const mistakesHTML=p.mistakes?`
    <div class="mistake-box">
      <h4>⚠️ Common mistakes</h4>
      ${p.mistakes.map(m=>`<div class="mistake-item">${md(m)}</div>`).join('')}
    </div>`:'';

  const hintsHTML=p.hints?`
    <div class="hint-box">
      <h4>💡 Hints</h4>
      ${p.hints.map(h=>`<div class="hint-item">${md(h)}</div>`).join('')}
    </div>`:'';

  const bonusHTML=p.bonus?`
    <div class="bonus-box">
      <h4>⭐ Bonus challenges</h4>
      ${p.bonus.map(b=>`<div class="bonus-item">${b}</div>`).join('')}
    </div>`:'';

  document.getElementById('py-inst').innerHTML=`
    <div class="tier-pill" style="background:${tier.bg};color:${tier.color}">${tier.label}</div>
    <h2>${p.icon} ${p.name}</h2>
    <div class="meta">${badges}</div>
    <p>${p.desc}</p>
    ${conceptHTML}
    ${expectedHTML}
    <h3>📋 Steps</h3>
    ${stepsHTML}
    ${mistakesHTML}
    ${hintsHTML}
    ${bonusHTML}
  `;
}

