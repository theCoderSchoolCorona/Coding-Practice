var PANEL_SIZES = ['inst-narrow','inst-medium','inst-wide'];
var PANEL_LABELS = ['Narrow','Medium','Wide'];
var currentPanelSize = 1; // default = medium (index 1 = inst-medium = 380px)

function setPanelSize(idx){
  var inst = document.getElementById('py-inst');
  if(!inst) return;
  currentPanelSize = idx;
  // Remove all size classes
  PANEL_SIZES.forEach(function(c){ inst.classList.remove(c); });
