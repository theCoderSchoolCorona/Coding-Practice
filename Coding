// STUDENT IDENTITY & SAVE/EXPORT/IMPORT SYSTEM
// ═══════════════════════════════════════════════════════════════
let STUDENT_NAME = '';

function initStudent(){
  try {
    const saved = localStorage.getItem('tcs_corona_student');
    if(saved){
      STUDENT_NAME = saved;
      showStudentBar();
      document.getElementById('name-modal').style.display = 'none';
    } else {
      document.getElementById('name-modal').style.display = 'flex';
      setTimeout(()=>{ const inp = document.getElementById('name-input'); if(inp) inp.focus(); }, 100);
    }
  } catch(e){
    // localStorage blocked (private mode etc) — just hide modal and continue
    document.getElementById('name-modal').style.display = 'none';
  }
}

function startWithName(){
  const inp = document.getElementById('name-input');
  const name = inp ? inp.value.trim() : '';
  if(!name){ inp.style.borderColor='#f87171'; inp.placeholder='Please enter your name'; return; }
  try { localStorage.setItem('tcs_corona_student', name); } catch(e){}
  STUDENT_NAME = name;
  showStudentBar();
  document.getElementById('name-modal').style.display = 'none';
}

function showStudentBar(){
  const bar = document.getElementById('student-bar');
  const lbl = document.getElementById('student-name-display');
  if(bar) bar.style.display = 'flex';
  if(lbl) lbl.textContent = STUDENT_NAME || '—';
}

// Allow pressing Enter in the name input
document.addEventListener('DOMContentLoaded', function(){
  const inp = document.getElementById('name-input');
  if(inp) inp.addEventListener('keydown', function(e){ if(e.key==='Enter') startWithName(); });
});

// ── EXPORT ────────────────────────────────────────────────────
function exportSave(){
  try {
    // Collect all tcs_corona_ keys from localStorage
    const data = { student: STUDENT_NAME, version: 1, saved: new Date().toISOString(), progress: {} };
    for(let i = 0; i < localStorage.length; i++){
      const k = localStorage.key(i);
      if(k && k.startsWith('tcs_corona_') && k !== 'tcs_corona_student'){
        data.progress[k] = localStorage.getItem(k);
      }
    }
    const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = 'tcs_progress_' + (STUDENT_NAME||'student').replace(/[^a-z0-9]/gi,'_') + '.json';
    a.click();
    URL.revokeObjectURL(url);
  } catch(e){ alert('Export failed: ' + e.message); }
}

// ── IMPORT (from header button) ───────────────────────────────
function triggerImport(){
  document.getElementById('import-file-input').click();
}

function importSave(event){
  const file = event.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      const data = JSON.parse(e.target.result);
      applyImportData(data);
    } catch(ex){ alert('Could not read save file: ' + ex.message); }
  };
  reader.readAsText(file);
  event.target.value = '';
}

// ── IMPORT (from welcome modal) ───────────────────────────────
function triggerImportModal(){
  document.getElementById('modal-import-input').click();
}

function importSaveModal(event){
  const file = event.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      const data = JSON.parse(e.target.result);
      applyImportData(data);
      document.getElementById('name-modal').style.display = 'none';
    } catch(ex){ alert('Could not read save file: ' + ex.message); }
  };
  reader.readAsText(file);
  event.target.value = '';
}

function applyImportData(data){
  if(!data || !data.progress) { alert('Invalid save file.'); return; }
  try {
    // Restore student name
    if(data.student){
      STUDENT_NAME = data.student;
      localStorage.setItem('tcs_corona_student', STUDENT_NAME);
      showStudentBar();
    }
    // Restore all progress keys
    Object.entries(data.progress).forEach(([k,v]) => {
      if(k.startsWith('tcs_corona_')) localStorage.setItem(k, v);
    });
    // Rebuild both sidebars with loaded state
    buildSidebar_PY();
    if(activeCurr !== 'py') buildSidebar_REF();
    // Show confirmation
    const done = Object.keys(data.progress).length;
    alert('Progress loaded for ' + (data.student||'student') + '! (' + done + ' lessons completed)');
  } catch(ex){ alert('Import error: ' + ex.message); }
}

// ── RESET ─────────────────────────────────────────────────────
function confirmReset(){
  if(!confirm('Reset ALL progress for ' + STUDENT_NAME + '? This cannot be undone.')) return;
  try {
    // Remove all tcs_corona_ keys
    const toRemove = [];
    for(let i = 0; i < localStorage.length; i++){
      const k = localStorage.key(i);
      if(k && k.startsWith('tcs_corona_')) toRemove.push(k);
    }
    toRemove.forEach(k => localStorage.removeItem(k));
    // Rebuild sidebars
    buildSidebar_PY();
    if(activeCurr !== 'py') buildSidebar_REF();
    alert('Progress reset. Good luck!');
  } catch(e){}
}

// ═══════════════════════════════════════════════════════════════
// PROGRESS TRACKING  (localStorage — same browser = persists)
// ═══════════════════════════════════════════════════════════════
const PROG = {
  key: function(course, idx){ return 'tcs_corona_' + course + '_' + idx; },

  isDone: function(course, idx){
    try { return localStorage.getItem(PROG.key(course, idx)) === '1'; }
    catch(e){ return false; }
  },

  setDone: function(course, idx, done){
    try {
      if(done) localStorage.setItem(PROG.key(course, idx), '1');
      else     localStorage.removeItem(PROG.key(course, idx));
    } catch(e){}
  },

  countDone: function(course, total){
    let n = 0;
    for(let i = 0; i < total; i++){ if(PROG.isDone(course, i)) n++; }
    return n;
  },

  clearCourse: function(course, total){
    for(let i = 0; i < total; i++){
      try{ localStorage.removeItem(PROG.key(course, i)); } catch(e){}
    }
  }
};

// Inject a progress bar at the top of a sidebar
function injectProgressBar(sbId, course, total){
  const sb = document.getElementById(sbId);
  if(!sb) return;
  const done = PROG.countDone(course, total);
  const pct  = total > 0 ? Math.round((done / total) * 100) : 0;
  // Remove old bar if present
  const old = sb.querySelector('.progress-bar-wrap');
  if(old) old.remove();
  const bar = document.createElement('div');
  bar.className = 'progress-bar-wrap';
  bar.innerHTML = `
    <div class="progress-bar-label">
      <span>Progress</span>
      <span>${done} / ${total} (${pct}%)</span>
    </div>
    <div class="progress-bar-track">
      <div class="progress-bar-fill" style="width:${pct}%"></div>
    </div>`;
  sb.insertBefore(bar, sb.firstChild);
}

// Add ✓ check icon to a tab and style it done/undone
function updateTab(tabEl, done){
  if(!tabEl) return;
  tabEl.classList.toggle('done', done);
  let chk = tabEl.querySelector('.check');
  if(!chk){
    chk = document.createElement('span');
    chk.className = 'check';
    chk.textContent = '✓';
    tabEl.appendChild(chk);
  }
}

// Render a "Mark Complete" button into the current lesson page
function renderMarkBtn(course, idx, total){
  // Remove any existing btn
  const old = document.querySelector('.mark-btn');
  if(old) old.remove();
  const done = PROG.isDone(course, idx);
  const btn  = document.createElement('button');
  btn.className = 'mark-btn' + (done ? ' done' : '');
  btn.innerHTML  = done ? '✓ Completed' : '☐ Mark as Complete';
  if(!done){
    btn.onclick = function(){
      PROG.setDone(course, idx, true);
      btn.textContent = '✓ Completed';
      btn.classList.add('done');
      btn.onclick = null;
      // Update sidebar tab + progress bar
      if(course === 'py'){
        updateTab(document.getElementById('py-t' + idx), true);
        injectProgressBar('py-sidebar', 'py', P.length);
      } else {
        updateTab(document.getElementById('reftab' + idx), true);
        const c = activeCurr;
        const len = LESSONS.length;
        injectProgressBar('ref-sidebar', c, len);
      }
    };
  }
  // Insert at top of the lesson page
