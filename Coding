<div class="section">
  <h2>📝 Phase 4 — PlayerController.cs</h2>
  <p><strong>Create → MonoBehaviour Script → "PlayerController".</strong> Attach to your Player Capsule.</p>
  <pre><span class="cm">// Scripts/PlayerController.cs</span>
<span class="kw">using</span> UnityEngine;

<span class="kw">public class</span> <span class="ty">PlayerController</span> : <span class="uk">MonoBehaviour</span>, <span class="ty">IDamageable</span>
{
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">float</span>     moveSpeed  = <span class="num">7f</span>;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">float</span>     jumpForce  = <span class="num">6f</span>;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">float</span>     groundDist = <span class="num">1.1f</span>;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">LayerMask</span> groundMask;  <span class="cm">// set to "Ground" in Inspector</span>

    <span class="kw">private</span> <span class="ty">Rigidbody</span> rb;
    <span class="kw">private</span> <span class="ty">Vector3</span>   spawnPos;
    <span class="kw">private</span> <span class="ty">bool</span>      isAlive = <span class="kw">true</span>;
    <span class="kw">private</span> <span class="ty">bool</span>      isDead  = <span class="kw">false</span>;

    <span class="kw">void</span> <span class="fn">Awake</span>()
    {
        rb       = <span class="fn">GetComponent</span>&lt;<span class="ty">Rigidbody</span>&gt;();
        spawnPos = transform.position;
    }

    <span class="kw">void</span> <span class="fn">Update</span>()
    {
        <span class="kw">if</span> (!isAlive) <span class="kw">return</span>;
        <span class="kw">if</span> (<span class="uk">Input</span>.<span class="fn">GetKeyDown</span>(<span class="uk">KeyCode</span>.Space) &amp;&amp; <span class="fn">IsGrounded</span>())
            rb.<span class="fn">AddForce</span>(<span class="ty">Vector3</span>.up * jumpForce, <span class="uk">ForceMode</span>.Impulse);
    }

    <span class="kw">void</span> <span class="fn">FixedUpdate</span>()
    {
        <span class="kw">if</span> (!isAlive) <span class="kw">return</span>;
        <span class="ty">float</span>   h    = <span class="uk">Input</span>.<span class="fn">GetAxis</span>(<span class="str">"Horizontal"</span>);
        <span class="ty">float</span>   v    = <span class="uk">Input</span>.<span class="fn">GetAxis</span>(<span class="str">"Vertical"</span>);
        <span class="ty">Vector3</span> move = <span class="kw">new</span> <span class="ty">Vector3</span>(h, <span class="num">0</span>, v).normalized;
        rb.<span class="fn">MovePosition</span>(rb.position + move * moveSpeed * <span class="uk">Time</span>.fixedDeltaTime);
    }

    <span class="kw">bool</span> <span class="fn">IsGrounded</span>() =>
        <span class="uk">Physics</span>.<span class="fn">Raycast</span>(transform.position, <span class="ty">Vector3</span>.down, groundDist, groundMask);

    <span class="kw">public void</span> <span class="fn">TakeDamage</span>(<span class="ty">int</span> amount) { <span class="kw">if</span> (!isDead) <span class="fn">Die</span>(); }

    <span class="kw">public void</span> <span class="fn">Die</span>()
    {
        <span class="kw">if</span> (isDead) <span class="kw">return</span>;
        isDead = <span class="kw">true</span>; isAlive = <span class="kw">false</span>;
        <span class="ty">GameManager</span>.Instance.<span class="fn">PlayerDied</span>();
        <span class="kw">if</span> (<span class="ty">GameManager</span>.Instance.Lives > <span class="num">0</span>)
            <span class="fn">StartCoroutine</span>(<span class="fn">Respawn</span>());
    }

    System.Collections.<span class="ty">IEnumerator</span> <span class="fn">Respawn</span>()
    {
        <span class="ty">Renderer</span> rend = <span class="fn">GetComponent</span>&lt;<span class="ty">Renderer</span>&gt;();
        <span class="kw">for</span> (<span class="ty">int</span> i = <span class="num">0</span>; i &lt; <span class="num">5</span>; i++)
        {
            <span class="kw">if</span> (rend) rend.enabled = <span class="kw">false</span>;
            <span class="kw">yield return new</span> <span class="ty">WaitForSeconds</span>(<span class="num">0.1f</span>);
            <span class="kw">if</span> (rend) rend.enabled = <span class="kw">true</span>;
            <span class="kw">yield return new</span> <span class="ty">WaitForSeconds</span>(<span class="num">0.1f</span>);
        }
        transform.position = spawnPos;
        rb.velocity = <span class="ty">Vector3</span>.zero;
        isAlive = <span class="kw">true</span>; isDead = <span class="kw">false</span>;
    }
}</pre>
