        <span class="fn">Shoot</span>();
    }
}

<span class="kw">void</span> <span class="fn">Shoot</span>()
{
    <span class="ty">Ray</span> ray = Camera.main.<span class="fn">ScreenPointToRay</span>(<span class="uk">Input</span>.mousePosition);
    <span class="ty">RaycastHit</span> hit;

    <span class="kw">if</span> (<span class="uk">Physics</span>.<span class="fn">Raycast</span>(ray, <span class="kw">out</span> hit, <span class="num">100f</span>))
    {
