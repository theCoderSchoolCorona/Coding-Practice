}

function buildPanelSizeBtns(){
  var existing = document.getElementById('panel-size-btns');
  if(existing) return;
  var inst = document.getElementById('py-inst');
  if(!inst) return;
  var row = document.createElement('div');
  row.className = 'panel-size-btns';
  row.id = 'panel-size-btns';
  PANEL_LABELS.forEach(function(label, i){
    var btn = document.createElement('button');
    btn.className = 'psz-btn' + (i === currentPanelSize ? ' active' : '');
    btn.textContent = label;
    btn.onclick = function(){ setPanelSize(i); };
