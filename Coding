    <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">$"Hit normal: {hit.normal}"</span>);  <span class="cm">// surface direction</span>
}

<span class="cm">// Visualise the ray in the Scene view (editor only)</span>
<span class="uk">Debug</span>.<span class="fn">DrawRay</span>(transform.position, transform.forward * <span class="num">10f</span>, <span class="ty">Color</span>.red);</pre>
</div>
<div class="section">
  <h2>🎮 Shooting &amp; Interaction Patterns</h2>
  <pre><span class="cm">// ── Shooting from camera (FPS style) ──</span>
<span class="kw">void</span> <span class="fn">Update</span>()
{
    <span class="kw">if</span> (<span class="uk">Input</span>.<span class="fn">GetMouseButtonDown</span>(<span class="num">0</span>))
