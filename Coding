  <div class="badges"><span class="badge new">★ if/else if/else</span><span class="badge new">★ comparison operators</span><span class="badge new">★ logical operators</span><span class="badge new">★ ternary</span></div>
</div>

<div class="section">
  <h2>💻 If / Else Syntax</h2>
  <pre><span class="ty">int</span> health = <span class="num">75</span>;

<span class="kw">if</span> (health &gt; <span class="num">50</span>)
{
    <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Healthy"</span>);
}
<span class="kw">else if</span> (health &gt; <span class="num">25</span>)
{
