{tier:4,icon:"🌐",name:"RemoteEvents",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(52,211,153,0.1);color:#34d399">Tier 5 — Roblox Gameplay</div>
  <h1>🌐 RemoteEvents — Client &amp; Server Communication</h1>
  <p>The server and clients can't directly call each other's code. RemoteEvents are the bridge between them.</p>
  <div class="badges"><span class="badge rb">★ RemoteEvent</span><span class="badge rb">★ FireServer</span><span class="badge rb">★ FireClient</span><span class="badge rb">★ OnServerEvent</span><span class="badge rb">★ OnClientEvent</span></div>
</div>

<div class="section">
  <h2>🔄 How RemoteEvents Work</h2>
  <table class="ctable">
    <tr><th>Direction</th><th>From</th><th>Method</th><th>Listener</th></tr>
    <tr><td>Client → Server</td><td>LocalScript</td><td><code>event:FireServer(data)</code></td><td><code>event.OnServerEvent:Connect(...)</code></td></tr>
    <tr><td>Server → One client</td><td>Script</td><td><code>event:FireClient(player, data)</code></td><td><code>event.OnClientEvent:Connect(...)</code></td></tr>
    <tr><td>Server → All clients</td><td>Script</td><td><code>event:FireAllClients(data)</code></td><td><code>event.OnClientEvent:Connect(...)</code></td></tr>
  </table>
  <div class="note-box">⚠️ <strong>NEVER trust the client!</strong> Always validate data sent from a client on the server. Players can send fake RemoteEvent calls.</div>
</div>

<div class="section">
  <h2>💻 RemoteEvent Setup &amp; Usage</h2>
  <pre><span class="cm">-- Step 1: Create RemoteEvent in ReplicatedStorage (once, in Studio)</span>
<span class="cm">-- Or create it in a Script:</span>
<span class="kw">local</span> event = <span class="rb">Instance</span>.<span class="fn">new</span>(<span class="str">"RemoteEvent"</span>)
event.Name   = <span class="str">"DamageEvent"</span>
event.Parent = game:<span class="fn">GetService</span>(<span class="str">"ReplicatedStorage"</span>)

<span class="cm">-- ══ SERVER SCRIPT ══</span>
<span class="kw">local</span> ReplicatedStorage = game:<span class="fn">GetService</span>(<span class="str">"ReplicatedStorage"</span>)
<span class="kw">local</span> damageEvent = ReplicatedStorage:WaitForChild(<span class="str">"DamageEvent"</span>)

<span class="cm">-- Listen for client sending damage request</span>
damageEvent.<span class="svc">OnServerEvent</span>:<span class="fn">Connect</span>(<span class="kw">function</span>(player, targetName, amount)
    <span class="cm">-- VALIDATE! Never trust the client</span>
    <span class="kw">if</span> <span class="fn">typeof</span>(amount) ~= <span class="str">"number"</span> <span class="kw">then</span> <span class="kw">return</span> <span class="kw">end</span>
    <span class="kw">if</span> amount &lt; <span class="num">0</span> <span class="kw">or</span> amount &gt; <span class="num">100</span> <span class="kw">then</span> <span class="kw">return</span> <span class="kw">end</span>

    <span class="kw">local</span> target = game.Players:<span class="fn">FindFirstChild</span>(targetName)
    <span class="kw">if</span> target <span class="kw">then</span>
        <span class="kw">local</span> hum = target.Character <span class="kw">and</span>
                    target.Character:<span class="fn">FindFirstChild</span>(<span class="str">"Humanoid"</span>)
        <span class="kw">if</span> hum <span class="kw">then</span> hum:<span class="fn">TakeDamage</span>(amount) <span class="kw">end</span>
    <span class="kw">end</span>
<span class="kw">end</span>)

<span class="cm">-- Send data TO a specific client</span>
damageEvent:<span class="fn">FireClient</span>(player, <span class="str">"ShowEffect"</span>, <span class="num">10</span>)

<span class="cm">-- Send to ALL clients</span>
damageEvent:<span class="fn">FireAllClients</span>(<span class="str">"GameOver"</span>)

<span class="cm">-- ══ LOCAL SCRIPT ══</span>
<span class="kw">local</span> damageEvent = ReplicatedStorage:WaitForChild(<span class="str">"DamageEvent"</span>)

<span class="cm">-- Fire to server (e.g. player pressed attack)</span>
damageEvent:<span class="fn">FireServer</span>(<span class="str">"EnemyPlayer"</span>, <span class="num">10</span>)

<span class="cm">-- Listen for server sending to this client</span>
damageEvent.<span class="svc">OnClientEvent</span>:<span class="fn">Connect</span>(<span class="kw">function</span>(message, value)
    <span class="rb">print</span>(<span class="str">"Server said: "</span> .. message)
<span class="kw">end</span>)</pre>
</div>

${Q([
  {q:"Where should RemoteEvents be stored so both server and client can access them?",opts:["ServerStorage","StarterGui","ReplicatedStorage","Workspace"],ans:2,explain:"ReplicatedStorage is accessible from both server Scripts and client LocalScripts — making it the perfect place for RemoteEvents, RemoteFunctions, and shared modules."},
  {q:"From a LocalScript, how do you send data TO the server?",opts:["event:FireClient(data)","event:FireServer(data)","event:FireAllClients(data)","event:SendToServer(data)"],ans:1,explain:"FireServer() sends from a LocalScript (client) to the server Script. Note: the server listener automatically receives the player as the first parameter."},
  {q:"On the server, how do you listen for a client firing a RemoteEvent?",opts:["event.OnClientEvent:Connect()","event.Fired:Connect()","event.OnServerEvent:Connect()","event:Listen()"],ans:2,explain:"OnServerEvent fires on the server when any client calls FireServer(). The callback automatically receives (player, ...args) — the player who fired it is always first."},
  {q:"Why must you ALWAYS validate data received from a client on the server?",opts:["It's optional","Clients can send any data — including invalid or malicious values — so always check before using","For performance","The data might be nil"],ans:1,explain:"Exploiters can use executors to fire RemoteEvents with any data they want. Never trust client data. Always validate types, ranges, and ownership on the server before acting on it."},
  {q:"You want to notify ALL players that the game is over. Which method do you use?",opts:["event:FireServer()","event:FireClient(player)","event:FireAllClients()","event:BroadcastAll()"],ans:2,explain:"FireAllClients() sends the event to every connected client simultaneously. Use it for announcements, game state changes, effects that everyone should see."},
])}

${FIB("Complete the client-to-server communication:",
`<span class="cm">-- LOCALSCRIPT: player collects a coin</span>
<span class="kw">local</span> ReplicatedStorage = game:GetService(<span class="str">"ReplicatedStorage"</span>)
<span class="kw">local</span> coinEvent = ReplicatedStorage:${blank('WaitForChild',14)}(<span class="str">"CoinEvent"</span>)

<span class="cm">-- Tell server we collected a coin</span>
coinEvent:${blank('FireServer',11)}(<span class="str">"collected"</span>, <span class="num">10</span>)

<span class="cm">-- Listen for server response</span>
coinEvent.${blank('OnClientEvent',14)}:Connect(<span class="kw">function</span>(message)
    print(message)
<span class="kw">end</span>)

<span class="cm">-- SERVER SCRIPT: handle the event</span>
coinEvent.${blank('OnServerEvent',14)}:Connect(<span class="kw">function</span>(${blank('player',7)}, action, amount)
    <span class="kw">if</span> action == <span class="str">"collected"</span> <span class="kw">then</span>
        player.leaderstats.Coins.Value += amount
        coinEvent:${blank('FireClient',11)}(player, <span class="str">"Coin collected!"</span>)
    <span class="kw">end</span>
<span class="kw">end</span>)`,
['WaitForChild','FireServer','OnClientEvent','OnServerEvent','player','FireClient'])}

${BUG("This code lets players buy items but has a serious security flaw:",
`-- LOCAL SCRIPT
local buyEvent = ReplicatedStorage:WaitForChild("BuyEvent")
buyEvent:FireServer("Sword", -100)  -- pay -100 coins (gain coins instead!)

-- SERVER SCRIPT  
buyEvent.OnServerEvent:Connect(function(player, item, price)
    player.leaderstats.Coins.Value = player.leaderstats.Coins.Value - price
end)`,
["The event name is wrong","The server doesn't validate the price — a negative price would ADD coins. Always validate on the server.","FireServer should be FireClient","The item should be an Instance not a string"],1,
"The server blindly subtracts whatever price the client sends. A player could send -100 as the price to gain coins. Fix: validate on the server that price > 0, that the item exists, and that the player can afford it — never trust client data.")}

${CHALLENGES([
  "Build a shop: client clicks a buy button → fires RemoteEvent to server → server checks coins → deducts and gives item.",
  "Create a chat announcement system: when a player collects 100 coins, FireAllClients to show a message to everyone.",
  "Build a voting system: clients fire votes to server, server counts them and fires result back to all clients.",
  "Create a secure damage event: client fires it, server validates the target is a valid enemy (not a player) before dealing damage.",
  "Build a round system: server fires round start/end events to all clients, clients show a countdown UI.",
])}
`},

