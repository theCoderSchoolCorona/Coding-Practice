{tier:2,icon:"⚙️",name:"Functions",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(251,191,36,0.1);color:#fbbf24">Tier 3 — Functions &amp; Tables</div>
  <h1>⚙️ Functions</h1>
  <p>Functions are reusable blocks of code. Lua functions can return multiple values and be stored in variables.</p>
  <div class="badges"><span class="badge new">★ function syntax</span><span class="badge new">★ parameters</span><span class="badge new">★ return values</span><span class="badge new">★ multiple returns</span><span class="badge new">★ closures</span></div>
</div>

<div class="section">
  <h2>💻 Function Syntax</h2>
  <pre><span class="cm">-- Standard function declaration</span>
<span class="kw">local function</span> <span class="fn">greet</span>(name)
    <span class="rb">print</span>(<span class="str">"Hello "</span> .. name .. <span class="str">"!"</span>)
<span class="kw">end</span>

<span class="cm">-- Function stored in a variable (same thing)</span>
<span class="kw">local</span> <span class="fn">greet</span> = <span class="kw">function</span>(name)
    <span class="rb">print</span>(<span class="str">"Hello "</span> .. name .. <span class="str">"!"</span>)
<span class="kw">end</span>

<span class="cm">-- Calling functions</span>
<span class="fn">greet</span>(<span class="str">"Alex"</span>)    <span class="cm">-- Hello Alex!</span>
<span class="fn">greet</span>(<span class="str">"Sam"</span>)     <span class="cm">-- Hello Sam!</span>

<span class="cm">-- Function with return value</span>
<span class="kw">local function</span> <span class="fn">add</span>(a, b)
    <span class="kw">return</span> a + b
<span class="kw">end</span>

<span class="kw">local</span> result = <span class="fn">add</span>(<span class="num">3</span>, <span class="num">5</span>)
<span class="rb">print</span>(result)   <span class="cm">-- 8</span>

<span class="cm">-- MULTIPLE RETURN VALUES (unique to Lua!)</span>
<span class="kw">local function</span> <span class="fn">minMax</span>(a, b, c)
    <span class="kw">local</span> mn = math.<span class="fn">min</span>(a, b, c)
    <span class="kw">local</span> mx = math.<span class="fn">max</span>(a, b, c)
    <span class="kw">return</span> mn, mx
<span class="kw">end</span>

<span class="kw">local</span> low, high = <span class="fn">minMax</span>(<span class="num">3</span>, <span class="num">7</span>, <span class="num">1</span>)
<span class="rb">print</span>(low, high)   <span class="cm">-- 1  7</span></pre>

  <div class="tip-box">💡 <strong>Multiple returns</strong> are a powerful Lua feature! A function can return several values at once — unpack them into separate variables.</div>
</div>

<div class="section">
  <h2>🔒 Variable Arguments &amp; Closures</h2>
  <pre><span class="cm">-- Variable arguments with ...</span>
<span class="kw">local function</span> <span class="fn">printAll</span>(...)
    <span class="kw">local</span> args = {...}
    <span class="kw">for</span> i, v <span class="kw">in</span> <span class="fn">ipairs</span>(args) <span class="kw">do</span>
        <span class="rb">print</span>(i, v)
    <span class="kw">end</span>
<span class="kw">end</span>
<span class="fn">printAll</span>(<span class="str">"a"</span>, <span class="str">"b"</span>, <span class="str">"c"</span>, <span class="str">"d"</span>)

<span class="cm">-- Default parameter pattern (Lua doesn't have built-in defaults)</span>
<span class="kw">local function</span> <span class="fn">takeDamage</span>(amount, isCrit)
    amount = amount <span class="kw">or</span> <span class="num">10</span>           <span class="cm">-- default 10 if nil</span>
    isCrit = isCrit <span class="kw">or</span> <span class="kw">false</span>        <span class="cm">-- default false if nil</span>
    <span class="kw">if</span> isCrit <span class="kw">then</span> amount = amount * <span class="num">2</span> <span class="kw">end</span>
    <span class="rb">print</span>(<span class="str">"Damage: "</span> .. amount)
<span class="kw">end</span>

<span class="fn">takeDamage</span>(<span class="num">15</span>)          <span class="cm">-- Damage: 15</span>
<span class="fn">takeDamage</span>(<span class="num">15</span>, <span class="kw">true</span>)   <span class="cm">-- Damage: 30</span>
<span class="fn">takeDamage</span>()            <span class="cm">-- Damage: 10 (default)</span></pre>
</div>

${Q([
  {q:"In Lua, functions must be defined BEFORE they are called — when using <code>local function</code>. Why?",opts:["It's just a style rule","local functions aren't visible before their declaration in the file","Functions are always visible","It depends on the script type"],ans:1,explain:"local function creates a variable scoped to the current block. You can't call it before the line where it's defined. To call functions out of order, you'd need forward declaration or non-local functions."},
  {q:"How many values can a Lua function return?",opts:["One only","Two maximum","Any number — Lua supports multiple return values","Zero or one"],ans:2,explain:"Lua uniquely allows functions to return multiple values: return a, b, c. Unpack them with: local x, y, z = myFunction()."},
  {q:"What does the pattern <code>amount = amount or 10</code> do?",opts:["Always sets amount to 10","Sets amount to 10 only if amount is nil or false","Adds 10 to amount","Compares amount to 10"],ans:1,explain:"This is the Lua default parameter idiom. If amount is nil (not passed), the 'or' returns 10. It's a substitute for default parameters since Lua doesn't have them built in."},
  {q:"Which is the correct way to declare a local function in Lua?",opts:["function local greet()","void greet()","local function greet()","def greet():"],ans:2,explain:"'local function greet()' is the standard way. It's equivalent to 'local greet = function()'. The word 'local' must come first."},
  {q:"What does <code>...</code> (three dots) mean in a function parameter list?",opts:["A comment","An optional parameter","A variable number of arguments (varargs)","A table parameter"],ans:2,explain:"... is Lua's varargs syntax. It captures any number of arguments passed to the function. Access them with local args = {...} to put them in a table."},
])}

${FIB("Complete the damage calculation functions:",
`<span class="kw">local</span> ${blank('function',9)} calculateDamage(base, multiplier)
    multiplier = multiplier ${blank('or',3)} <span class="num">1</span>   <span class="cm">-- default multiplier</span>
    <span class="kw">return</span> math.${blank('floor',6)}(base * multiplier)
<span class="kw">end</span>

<span class="kw">local function</span> getStats(health, maxHealth)
    <span class="kw">local</span> pct = (health / maxHealth) * <span class="num">100</span>
    <span class="kw">local</span> status
    <span class="kw">if</span> pct > <span class="num">50</span> then status = <span class="str">"Healthy"</span>
    ${blank('elseif',7)} pct > <span class="num">25</span> then status = <span class="str">"Low"</span>
    else status = <span class="str">"Critical"</span>
    <span class="kw">end</span>
    <span class="kw">return</span> pct, ${blank('status',7)}
<span class="kw">end</span>

<span class="kw">local</span> dmg = calculateDamage(<span class="num">50</span>, <span class="num">1.5</span>)
<span class="kw">local</span> percent, msg = ${blank('getStats',9)}(<span class="num">30</span>, <span class="num">100</span>)
<span class="rb">print</span>(dmg, percent, msg)`,
['function','or','floor','elseif','status','getStats'])}

${BUG("This function should return both min and max of two numbers but it's broken:",
`local function getMinMax(a, b)
    if a < b then
        return a
        return b
