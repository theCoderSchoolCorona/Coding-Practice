// ════ NEW ROBLOX: METATABLES / OOP ═══════════════════════════
,{tier:2,icon:"🧬",name:"OOP with Metatables",build:()=>`
<div class="lesson-header">
  <div class="tier-pill" style="background:rgba(251,191,36,0.1);color:#fbbf24">Tier 3 — Functions &amp; Tables</div>
  <h1>🧬 OOP with Metatables</h1>
  <p>Lua doesn't have built-in classes, but metatables let you build them. This is the pattern used in almost every professional Roblox project.</p>
  <div class="badges"><span class="badge new">★ metatables</span><span class="badge new">★ __index</span><span class="badge new">★ :new() pattern</span><span class="badge new">★ self / colon syntax</span></div>
</div>
<div class="section">
  <h2>💻 The Class Pattern</h2>
  <pre><span class="cm">-- Step 1: Create the class table</span>
<span class="kw">local</span> <span class="fn">Enemy</span> = {}
<span class="fn">Enemy</span>.__index = <span class="fn">Enemy</span>   <span class="cm">-- makes instances find methods on Enemy</span>

<span class="cm">-- Step 2: Constructor</span>
<span class="kw">function</span> <span class="fn">Enemy</span>.<span class="fn">new</span>(name, health, damage)
    <span class="kw">local</span> self = setmetatable({}, <span class="fn">Enemy</span>)   <span class="cm">-- new instance pointing to Enemy</span>
    self.name   = name
    self.health = health
    self.damage = damage
    self.alive  = <span class="kw">true</span>
    <span class="kw">return</span> self
<span class="kw">end</span>

<span class="cm">-- Step 3: Methods (use colon syntax — auto-inserts self)</span>
<span class="kw">function</span> <span class="fn">Enemy</span>:<span class="fn">takeDamage</span>(amount)
    self.health = self.health - amount
    <span class="rb">print</span>(self.name .. <span class="str">" took "</span> .. amount .. <span class="str">" damage. HP: "</span> .. self.health)
    <span class="kw">if</span> self.health &lt;= <span class="num">0</span> <span class="kw">then</span>
        self:<span class="fn">die</span>()
    <span class="kw">end</span>
<span class="kw">end</span>

<span class="kw">function</span> <span class="fn">Enemy</span>:<span class="fn">die</span>()
    self.alive = <span class="kw">false</span>
    <span class="rb">print</span>(self.name .. <span class="str">" has died!"</span>)
<span class="kw">end</span>

<span class="kw">function</span> <span class="fn">Enemy</span>:<span class="fn">attack</span>(target)
    <span class="rb">print</span>(self.name .. <span class="str">" attacks "</span> .. target.name .. <span class="str">" for "</span> .. self.damage)
    target:<span class="fn">takeDamage</span>(self.damage)
<span class="kw">end</span>

<span class="cm">-- Step 4: Create instances</span>
<span class="kw">local</span> goblin = <span class="fn">Enemy</span>.<span class="fn">new</span>(<span class="str">"Goblin"</span>, <span class="num">50</span>, <span class="num">10</span>)
<span class="kw">local</span> orc    = <span class="fn">Enemy</span>.<span class="fn">new</span>(<span class="str">"Orc"</span>,    <span class="num">150</span>, <span class="num">25</span>)

goblin:<span class="fn">takeDamage</span>(<span class="num">30</span>)
orc:<span class="fn">attack</span>(goblin)</pre>
  <div class="lua-box">💡 <strong>Colon vs dot:</strong> <code>function Enemy:takeDamage(amount)</code> is shorthand for <code>function Enemy.takeDamage(self, amount)</code>. The colon automatically inserts <code>self</code> as the first parameter. Use colon when calling too: <code>goblin:takeDamage(10)</code>.</div>
</div>
<div class="section">
  <h2>🔗 Inheritance Pattern</h2>
  <pre><span class="kw">local</span> <span class="fn">Boss</span> = setmetatable({}, {__index = <span class="fn">Enemy</span>})
<span class="fn">Boss</span>.__index = <span class="fn">Boss</span>

<span class="kw">function</span> <span class="fn">Boss</span>.<span class="fn">new</span>(name)
    <span class="kw">local</span> self = <span class="fn">Enemy</span>.<span class="fn">new</span>(name, <span class="num">500</span>, <span class="num">50</span>)  <span class="cm">-- reuse parent constructor</span>
    <span class="kw">return</span> setmetatable(self, <span class="fn">Boss</span>)
<span class="kw">end</span>

<span class="kw">function</span> <span class="fn">Boss</span>:<span class="fn">specialAttack</span>()   <span class="cm">-- new method</span>
    <span class="rb">print</span>(self.name .. <span class="str">" uses RAGE!"</span>)
    self.damage = self.damage * <span class="num">2</span>
<span class="kw">end</span>

<span class="kw">function</span> <span class="fn">Boss</span>:<span class="fn">die</span>()   <span class="cm">-- override parent method</span>
    <span class="fn">Enemy</span>.<span class="fn">die</span>(self)      <span class="cm">-- call parent version</span>
    <span class="rb">print</span>(<span class="str">"BOSS DEFEATED! Dropping loot..."</span>)
<span class="kw">end</span>

<span class="kw">local</span> dragonBoss = <span class="fn">Boss</span>.<span class="fn">new</span>(<span class="str">"Dragon"</span>)
dragonBoss:<span class="fn">attack</span>(goblin)       <span class="cm">-- inherited from Enemy</span>
dragonBoss:<span class="fn">specialAttack</span>()      <span class="cm">-- Boss-only method</span></pre>
</div>
${Q([
