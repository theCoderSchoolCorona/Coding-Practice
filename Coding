<div class="section">
  <h2>💻 Declaring &amp; Using Variables</h2>
  <pre><span class="cm">-- Single line comment in Lua uses --</span>
<span class="cm">--[[ Multi-line
     comment ]]</span>

<span class="cm">-- Declaring variables</span>
<span class="kw">local</span> score    = <span class="num">0</span>
<span class="kw">local</span> speed    = <span class="num">16</span>
<span class="kw">local</span> name     = <span class="str">"Alex"</span>
<span class="kw">local</span> isAlive  = <span class="kw">true</span>
<span class="kw">local</span> nothing  = <span class="kw">nil</span>

<span class="cm">-- Arithmetic</span>
score = score + <span class="num">10</span>
score = score - <span class="num">5</span>
score = score * <span class="num">2</span>
score = score / <span class="num">4</span>
score = score % <span class="num">3</span>     <span class="cm">-- modulo (remainder)</span>
score = score ^ <span class="num">2</span>     <span class="cm">-- power (exponent)</span>
score = math.floor(score) <span class="cm">-- round down</span>

<span class="cm">-- Lua does NOT have ++ or +=</span>
score = score + <span class="num">1</span>    <span class="cm">-- must write this in full</span>

<span class="cm">-- Check the type</span>
