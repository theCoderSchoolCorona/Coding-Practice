// ═══════════════════════════ INTERACTION ═══════════════════════════
function ansQ(qid,chosen,correct,scId){
  if(answered[qid])return;
  answered[qid]=true;
  for(let i=0;i<6;i++){
    const el=document.getElementById(`${qid}_o${i}`);
    if(!el)continue;
    if(i===correct)el.classList.add('correct');
    else if(i===chosen)el.classList.add('wrong');
    el.onclick=null;
    el.style.cursor='default';
  }
  const fb=document.getElementById(`${qid}_fb`);
  if(fb){
    fb.className='q-feedback show '+(chosen===correct?'ok':'bad');
    fb.textContent=chosen===correct?'✓ Correct!':'✗ Not quite — the correct answer is highlighted above.';
  }
  const sc=document.getElementById(scId);
  if(sc&&chosen===correct){
    const parts=sc.textContent.split('/');
    sc.textContent=`${(parseInt(parts[0])||0)+1} / ${parts[1].trim()}`;
    sc.style.color='var(--success)';
  }
}

function ansB(id,chosen,correct,explain){
  if(answered['b'+id])return;
  answered['b'+id]=true;
  for(let i=0;i<6;i++){
    const el=document.getElementById(`${id}_o${i}`);
    if(!el)continue;
    if(i===correct)el.classList.add('correct');
    else if(i===chosen)el.classList.add('wrong');
    el.onclick=null;el.style.cursor='default';
  }
  const fb=document.getElementById(`${id}_fb`);
  if(fb){
    fb.className='bug-feedback show '+(chosen===correct?'ok':'bad');
    fb.innerHTML=(chosen===correct?'✓ Found it! ':'✗ Not quite. ')+explain;
  }
}

function normalise(s){
  // Remove trailing ()  ;  and whitespace, lowercase
  return s.trim().toLowerCase().replace(/\s+/g,' ').replace(/[();]+$/,'').trim();
}
function checkFIB(id){
  const blanks=document.querySelectorAll(`#${id}_code .blank`);
  let ok=0;
  blanks.forEach(b=>{
    const val  = normalise(b.value);
    const ans  = normalise(b.dataset.ans||'');
    // alts: pipe-separated list of additional accepted answers
    const alts = (b.dataset.alts||'').split('|').map(normalise).filter(Boolean);
    // also auto-generate alt without/with () suffix
    const autoAlts = [ans, ans+'()', ans.replace(/\(\)$/,'')].map(normalise);
    const allAccepted = [...new Set([ans, ...alts, ...autoAlts])];
    const correct = val===ans || allAccepted.includes(val);
    b.classList.toggle('correct', correct);
    b.classList.toggle('wrong',  !correct);
    if(correct) ok++;
  });
  const res=document.getElementById(`${id}_res`);
  if(res){
    res.style.color=ok===blanks.length?'var(--success)':'var(--warn)';
    res.textContent=ok===blanks.length
      ?`✓ All ${ok} correct! Great work!`
      :`${ok} / ${blanks.length} correct — check the red boxes.`;
  }
}

function revealFIB(id,answers){
  const blanks=document.querySelectorAll(`#${id}_code .blank`);
  blanks.forEach((b,i)=>{
    b.value=b.dataset.ans||answers[i]||'';
    b.classList.add('correct');b.classList.remove('wrong');
  });
  const res=document.getElementById(`${id}_res`);
  if(res){res.style.color='var(--muted)';res.textContent='Answers revealed — study them then reset and try again!';}
}

function resetFIB(id){
  const blanks=document.querySelectorAll(`#${id}_code .blank`);
  blanks.forEach(b=>{b.value='';b.classList.remove('correct','wrong');});
  const res=document.getElementById(`${id}_res`);
  if(res){res.textContent='';}
}

function blank(ans,size,alts){
  const altAttr=alts?` data-alts="${alts}"`:' ';
  return `<input class="blank" data-ans="${ans}"${altAttr} size="${size||Math.max(ans.length+2,5)}" spellcheck="false">`;
}

