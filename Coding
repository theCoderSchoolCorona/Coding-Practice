  let h=`<div class="quiz-section" id="${sid}"><h2>🧪 Knowledge Check <span class="qscore" id="${sid}sc">0 / ${tot}</span></h2>`;
  questions.forEach((q,qi)=>{
    const qid=`${sid}_${qi}`;
    h+=`<div class="q-item" id="${qid}"><div class="q-text">${q.q}</div><div class="options">`;
