.reset-btn2:hover{border-color:#f87171;color:#f87171}
.fib-result{font-size:12px;min-height:18px}

/* SPOT THE BUG */
.bug-section{background:var(--panel);border:1px solid rgba(251,191,36,0.25);border-radius:12px;padding:18px;margin-bottom:14px}
.bug-section h2{font-size:14px;font-weight:600;color:var(--warn);margin-bottom:6px;display:flex;align-items:center;gap:7px}
.bug-section .bugdesc{font-size:12px;color:var(--muted);margin-bottom:10px}
.bug-code{background:#090b14;border:1px solid rgba(251,191,36,0.2);border-radius:8px;padding:14px;font-family:'Space Mono',monospace;font-size:12px;line-height:1.9;margin-bottom:10px;white-space:pre-wrap}
.bug-opts{display:flex;flex-direction:column;gap:5px;margin-bottom:10px}
.bug-opt{background:var(--panel2);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-size:12px;cursor:pointer;transition:all 0.15s;color:var(--muted);display:flex;align-items:flex-start;gap:8px}
.bug-opt:hover{border-color:var(--warn);color:var(--text)}
.bug-opt.correct{border-color:var(--success)!important;color:var(--success)!important;background:rgba(52,211,153,0.07)!important}
.bug-opt.wrong{border-color:var(--error)!important;color:var(--error)!important;background:rgba(248,113,113,0.07)!important}
.bug-feedback{font-size:12px;padding:8px 12px;border-radius:6px;display:none;line-height:1.55}
.bug-feedback.show{display:block}
.bug-feedback.ok{background:rgba(52,211,153,0.08);border:1px solid rgba(52,211,153,0.2);color:#86efac}
.bug-feedback.bad{background:rgba(248,113,113,0.07);border:1px solid rgba(248,113,113,0.2);color:#fca5a5}

/* CHALLENGES */
.challenge-section{background:rgba(192,132,252,0.05);border:1px solid rgba(192,132,252,0.2);border-radius:12px;padding:16px;margin-bottom:14px}
.challenge-section h2{font-size:13px;font-weight:600;color:var(--accent2);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.challenge-item{display:flex;gap:10px;margin-bottom:8px;font-size:12px;color:#d8b4fe;line-height:1.5;padding:8px 10px;background:rgba(167,139,250,0.06);border-radius:6px;border:1px solid rgba(167,139,250,0.1)}
.challenge-item:last-child{margin-bottom:0}
.ch-num{background:rgba(167,139,250,0.2);color:var(--accent2);width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;margin-top:1px}

/* CHEATSHEET */
.cheat-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.cheat-card{background:var(--panel2);border:1px solid var(--border);border-radius:8px;padding:12px}
.cheat-card h4{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:8px;letter-spacing:.5px;text-transform:uppercase}
.cheat-card pre{background:none;border:none;padding:0;margin:0;font-size:11px}

@media(max-width:700px){.compare,.cheat-grid{grid-template-columns:1fr}}


/* ── PROGRESS TRACKING ─────────────────────────────────────── */
.proj-tab .check{margin-left:auto;color:var(--success);font-size:11px;opacity:0;transition:opacity 0.2s}
