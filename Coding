.progress-bar-track{background:rgba(255,255,255,0.06);border-radius:4px;height:5px;overflow:hidden}
.progress-bar-fill{height:100%;border-radius:4px;background:var(--success);transition:width 0.4s ease}
.mark-btn{display:flex;align-items:center;gap:7px;margin:0 0 14px;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.3);color:var(--success);padding:8px 16px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s;width:fit-content}
