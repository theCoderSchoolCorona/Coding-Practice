    <div><div class="ml good">✓ RIGHT</div><div class="right-code">if (health > 50)<br>{<br>    Debug.Log("ok");<br>    Die();<br>} <span style="color:#6b7280">// use braces for multi-line</span></div></div>
  </div>
</div>

