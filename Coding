<span class="kw">if</span> (!isAlive)           <span class="cm">// same as if (isAlive == false)</span>

<span class="cm">// Switch statement — clean alternative to many else-ifs</span>
<span class="ty">int</span> day = <span class="num">3</span>;
<span class="kw">switch</span> (day)
{
    <span class="kw">case</span> <span class="num">1</span>: <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Monday"</span>);   <span class="kw">break</span>;
    <span class="kw">case</span> <span class="num">2</span>: <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Tuesday"</span>);  <span class="kw">break</span>;
    <span class="kw">case</span> <span class="num">3</span>: <span class="uk">Debug</span>.<span class="fn">Log</span>(<span class="str">"Wednesday"</span>); <span class="kw">break</span>;
