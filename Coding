    <tr><td><code>&&</code></td><td>AND (both true)</td><td><code>alive && hasKey</code></td><td>true only if BOTH are true</td></tr>
    <tr><td><code>||</code></td><td>OR (either true)</td><td><code>won || quit</code></td><td>true if AT LEAST ONE is true</td></tr>
    <tr><td><code>!</code></td><td>NOT (invert)</td><td><code>!isGameOver</code></td><td>true when isGameOver is false</td></tr>
  </table>
</div>

<div class="section">
  <h2>🎮 Ternary Operator &amp; Null Check</h2>
  <pre><span class="cm">// Ternary — compact if/else that returns a value</span>
<span class="cm">// condition ? value_if_true : value_if_false</span>
<span class="ty">string</span> status = health &gt; <span class="num">0</span> ? <span class="str">"Alive"</span> : <span class="str">"Dead"</span>;
<span class="ty">int</span>    bonus  = score &gt; <span class="num">100</span> ? <span class="num">50</span> : <span class="num">0</span>;

<span class="cm">// Checking booleans — no need for == true</span>
<span class="ty">bool</span> isAlive = <span class="kw">true</span>;
