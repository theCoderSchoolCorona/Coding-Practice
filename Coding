<span class="kw">using</span> UnityEngine;

<span class="kw">public class</span> <span class="ty">CameraFollow</span> : <span class="uk">MonoBehaviour</span>
{
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">Transform</span> target;
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">Vector3</span>   offset      = <span class="kw">new</span> <span class="ty">Vector3</span>(<span class="num">0</span>, <span class="num">8</span>, <span class="num">-6</span>);
    [<span class="uk">SerializeField</span>] <span class="kw">private</span> <span class="ty">float</span>     smoothSpeed = <span class="num">5f</span>;

    <span class="kw">void</span> <span class="fn">LateUpdate</span>()
    {
        <span class="kw">if</span> (target == <span class="kw">null</span>) <span class="kw">return</span>;
        <span class="ty">Vector3</span> desired  = target.position + offset;
        transform.position = <span class="ty">Vector3</span>.<span class="fn">Lerp</span>(transform.position, desired, smoothSpeed * <span class="uk">Time</span>.deltaTime);
        transform.<span class="fn">LookAt</span>(target);
    }
}
<span class="cm">// After attaching: drag Player into the Target field in the Inspector.</span></pre>
